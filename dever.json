{
  "name": "crm",
  "version": "0.1.1",
  "description": "Customer center, assets, operations, tasks, finance and organization resources",
  "depends": {
    "front": ">=0.1.0"
  },
  "skills": [
    "skills/SKILL.md"
  ],
  "front": {
    "sites": {
      "admin": {
        "api": "crm/admin",
        "auth": [
          {
            "key": "crm-center",
            "name": "客户中心",
            "icon": "handshake",
            "type": 1,
            "sort": 10,
            "children": [
              {
                "key": "crm-dashboard",
                "name": "数据看板",
                "icon": "chart-column",
                "type": 1,
                "sort": 0
              },
              {
                "key": "crm-customer-manage",
                "name": "客户管理",
                "icon": "contact-round",
                "type": 1,
                "sort": 1
              },
              {
                "key": "crm-business-config",
                "name": "业务配置",
                "icon": "settings-2",
                "type": 1,
                "sort": 2
              },
              {
                "key": "crm-org-manage",
                "name": "组织管理",
                "icon": "building-2",
                "type": 1,
                "sort": 3
              }
            ]
          }
        ]
      },
      "work": {
        "api": "crm/work",
        "page": "work",
        "auth": [
          {
            "key": "crm-work-customer-center",
            "name": "客户中心",
            "icon": "contact-round",
            "type": 1,
            "sort": 1
          }
        ],
        "config": {
          "name": "CRM 工作台",
          "subtitle": "客户中心",
          "description": "CRM 前台客户与任务入口",
          "logo": "crm/assets/work/images/logo.svg",
          "favicon": "crm/assets/work/images/favicon.svg"
        },
        "setting": {
          "appearance": {
            "theme": "light",
            "sidebar": "floating",
            "layout": "default",
            "direction": "ltr"
          },
          "runtime": {
            "skin": "default",
            "routerMode": "history",
            "shell": "app"
          }
        },
        "access": {
          "mode": "login",
          "authProvider": "crm_work"
        },
        "entry": "crm/work",
        "public": [
          "login",
          "feishu_login",
          "feishu_config"
        ]
      }
    }
  }
}
