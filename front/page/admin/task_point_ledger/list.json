{
  "page": {
    "name": "任务积分",
    "icon": "star",
    "parent": "crm-customer-manage",
    "sort": 4
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header"
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5",
        "children": {
          "toolbar-row": {
            "type": "row",
            "className": "flex-wrap items-center gap-3"
          },
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page"
      }
    ],
    "toolbar-row": [
      {
        "type": "form-input",
        "placeholder": "搜索任务结果、来源...",
        "value": "search.keyword",
        "mode": "search"
      },
      {
        "type": "form-select",
        "placeholder": "任务",
        "value": "search.task_id",
        "mode": "search",
        "option": {
          "model": "crm.NewTaskModel",
          "labelField": "name",
          "order": "stage_id asc,sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "name"
          ],
          "filters": {
            "status": "1"
          }
        }
      },
      {
        "type": "form-select",
        "placeholder": "获得人员",
        "value": "search.staff_id",
        "mode": "search",
        "option": {
          "model": "crm.NewStaffModel",
          "labelField": "name",
          "order": "id asc",
          "pageSize": 200,
          "searchFields": [
            "name",
            "phone"
          ],
          "filters": {
            "status": "1"
          }
        }
      },
      {
        "type": "form-select",
        "placeholder": "所属部门",
        "value": "search.department_id",
        "mode": "search",
        "option": {
          "model": "crm.NewDepartmentModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "code",
            "name"
          ],
          "filters": {
            "status": "1"
          }
        }
      },
      {
        "type": "form-input",
        "placeholder": "开始时间 YYYY-MM-DD",
        "value": "search.created_at_start",
        "mode": "search"
      },
      {
        "type": "form-input",
        "placeholder": "结束时间 YYYY-MM-DD",
        "value": "search.created_at_end",
        "mode": "search"
      },
      {
        "type": "show-button",
        "name": "搜索",
        "meta": {
          "variant": "default",
          "size": "sm",
          "searchSubmit": true
        }
      },
      {
        "type": "show-button",
        "name": "重置",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "to": "/crm/task_point_ledger/list"
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "rowKey": "id",
          "columns": [
            {
              "name": "客户",
              "value": "customer.name",
              "type": "show-base"
            },
            {
              "name": "资产",
              "value": "asset.asset_name",
              "type": "show-base"
            },
            {
              "name": "任务",
              "value": "task.name",
              "type": "show-base"
            },
            {
              "name": "协作待办",
              "value": "todo.sub_task_name",
              "type": "show-base"
            },
            {
              "name": "积分",
              "value": "points",
              "type": "show-base"
            },
            {
              "name": "获得人员",
              "value": "staff.name",
              "type": "show-base"
            },
            {
              "name": "所属部门",
              "value": "department.name",
              "type": "show-base"
            },
            {
              "name": "任务结果",
              "value": "result_value",
              "type": "show-base"
            },
            {
              "name": "来源",
              "value": "source",
              "type": "show-tag"
            },
            {
              "name": "创建时间",
              "value": "created_at",
              "type": "show-date"
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ]
  },
  "data": {
    "search": {
      "keyword": "",
      "task_id": "",
      "staff_id": "",
      "department_id": "",
      "created_at_start": "",
      "created_at_end": ""
    },
    "table": {
      "pageSize": 20,
      "searchFields": [
        "result_value",
        "source"
      ],
      "filterFields": [
        "task_id",
        "staff_id",
        "department_id",
        {
          "field": "created_at",
          "type": "date-range",
          "startKey": "created_at_start",
          "endKey": "created_at_end"
        }
      ]
    }
  },
  "state": {},
  "action": {}
}
