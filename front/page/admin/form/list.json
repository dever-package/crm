{
  "page": {
    "name": "任务表单",
    "icon": "clipboard-list",
    "parent": "crm-business-config",
    "sort": 2
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5",
        "children": {
          "toolbar-row": {
            "type": "row",
            "className": "flex-wrap items-center gap-3"
          },
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          },
          "feedback-shell": {
            "type": "container"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "name": "新增任务表单",
        "meta": {
          "variant": "default",
          "size": "sm",
          "icon": "plus"
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.create",
            "value": true
          }
        }
      }
    ],
    "toolbar-row": [
      {
        "type": "form-input",
        "placeholder": "搜索任务表单名称...",
        "value": "search.keyword",
        "mode": "search"
      },
      {
        "type": "show-button",
        "name": "搜索",
        "meta": {
          "variant": "default",
          "size": "sm",
          "searchSubmit": true
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "savePath": "crm/form/update",
          "rowKey": "id",
          "columns": [
            {
              "name": "表单ID",
              "value": "id",
              "type": "show-base"
            },
            {
              "name": "表单名称",
              "value": "name",
              "type": "show-base"
            },
            {
              "name": "字段数量",
              "value": "fields",
              "type": "show-base",
              "meta": {
                "format": "count",
                "countUnit": "个字段"
              }
            },
            {
              "name": "状态",
              "value": "status",
              "type": "form-switch",
              "meta": {
                "trueValue": 1,
                "falseValue": 2
              }
            },
            {
              "name": "排序",
              "value": "sort",
              "type": "show-base",
              "editor": "form-number",
              "trigger": "doubleClick"
            },
            {
              "name": "创建时间",
              "value": "created_at",
              "type": "show-date"
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "编辑",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.editFormId",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.edit",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "feedback-shell": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.edit",
          "pageRoute": "/crm/form/update",
          "title": "编辑任务表单",
          "size": "3xl",
          "width": "64rem",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.editFormId"
          },
          "bodyClassName": "px-6 py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.create",
          "pageRoute": "/crm/form/update",
          "title": "新增任务表单",
          "size": "3xl",
          "width": "64rem",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "bodyClassName": "px-6 py-2"
        }
      }
    ]
  },
  "data": {
    "search": {},
    "table": {
      "pageSize": 20,
      "searchFields": [
        "name"
      ],
      "filterFields": []
    },
    "actionTarget": {
      "editFormId": ""
    }
  },
  "state": {
    "dialog": {
      "edit": false,
      "create": false
    }
  },
  "action": {}
}
