{
  "page": {
    "name": "任务表单编辑",
    "parent": "crm/form/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/form/create",
        "name": "任务表单新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/form/update",
        "name": "任务表单编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "value": "form.name",
        "name": "表单名称",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "任务表单名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-array",
        "name": "表单字段",
        "value": "form.fields",
        "mode": "form",
        "info": "组合流程任务需要填写的线索信息、客户信息或客户资产字段，字段按排序从小到大展示。",
        "meta": {
          "pageRoute": "/crm/form_field/update",
          "addText": "添加表单字段",
          "drag": "sort",
          "itemName": "表单字段"
        }
      }
    ]
  },
  "data": {
    "form": {
      "_fields": ["name", "fields"],
      "service": "crm.setting.CrmHook.BuildFormForm",
      "id": "",
      "name": "",
      "fields": []
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "crm.setting.CrmHook.BeforeSaveForm"
      }
    }
  }
}
