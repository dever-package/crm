{
  "page": {
    "name": "租赁记录维护",
    "parent": "crm/business_object/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/business_object/create",
        "name": "租赁记录新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/business_object/update",
        "name": "租赁记录维护",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-select",
        "name": "负责部门",
        "value": "form.owner_department_id",
        "mode": "form",
        "option": {
          "model": "crm.NewDepartmentModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 100,
          "filters": {
            "status": 1
          }
        },
        "meta": {
          "formLayout": "horizontal",
          "clearOnChange": [
            "form.owner_staff_id"
          ]
        }
      },
      {
        "type": "form-select",
        "name": "负责人",
        "value": "form.owner_staff_id",
        "mode": "form",
        "option": {
          "model": "crm.NewStaffModel",
          "labelField": "name",
          "parentField": "department_id",
          "order": "id asc",
          "pageSize": 100,
          "searchFields": [
            "name",
            "phone"
          ],
          "filters": {
            "status": 1
          }
        },
        "meta": {
          "formLayout": "horizontal",
          "optionParams": {
            "parentId": "form.owner_department_id"
          }
        }
      },
      {
        "type": "form-textarea",
        "value": "form.remark",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "rows": 3
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": "",
      "owner_department_id": "",
      "owner_staff_id": "",
      "remark": "",
      "status": 1,
      "sort": 100
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "data": {
        "_partial": true,
        "id": "$form.id",
        "owner_department_id": "$form.owner_department_id",
        "owner_staff_id": "$form.owner_staff_id",
        "remark": "$form.remark",
        "status": "$form.status",
        "sort": "$form.sort"
      },
      "before": {
        "service": "crm.setting.CrmHook.BeforeSaveBusinessObject"
      }
    }
  }
}
