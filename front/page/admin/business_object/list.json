{
  "page": {
    "name": "租赁记录",
    "icon": "box",
    "parent": "crm-customer-manage",
    "sort": 3
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5",
        "children": {
          "toolbar-row": {
            "type": "row",
            "className": "flex-wrap items-center gap-2.5"
          },
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          },
          "feedback-shell": {
            "type": "container"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page"
      }
    ],
    "header-actions": [],
    "toolbar-row": [
      {
        "type": "form-input",
        "placeholder": "搜索租赁编号、租户、状态...",
        "value": "search.keyword",
        "mode": "search"
      },
      {
        "type": "form-select",
        "placeholder": "记录类型",
        "value": "search.business_object_type_id",
        "mode": "search",
        "option": {
          "model": "crm.NewBusinessObjectTypeModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "code",
            "name"
          ],
          "filters": {
            "status": 1
          }
        }
      },
      {
        "type": "show-button",
        "name": "搜索",
        "meta": {
          "variant": "default",
          "size": "sm",
          "searchSubmit": true
        }
      },
      {
        "type": "show-button",
        "name": "重置",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "to": "/crm/business_object/list"
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "savePath": "crm/business_object/update",
          "rowKey": "id",
          "columns": [
            {
              "value": "object_name",
              "name": "租户/对象",
              "type": "show-base"
            },
            {
              "value": "object_no",
              "name": "租赁编号",
              "type": "show-base"
            },
            {
              "value": "business_object_type.name",
              "name": "记录类型",
              "type": "show-base"
            },
            {
              "value": "customer.name",
              "name": "所属客户",
              "type": "show-base"
            },
            {
              "value": "asset.asset_name",
              "name": "所属资产",
              "type": "show-base"
            },
            {
              "value": "object_status_name",
              "name": "租赁状态",
              "type": "show-tag"
            },
            {
              "value": "status",
              "type": "form-switch",
              "meta": {
                "trueValue": 1,
                "falseValue": 2
              }
            },
            {
              "value": "updated_at",
              "name": "更新时间",
              "type": "show-date"
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "编辑",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.businessObjectId",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.edit",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "feedback-shell": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.edit",
          "pageRoute": "/crm/business_object/update",
          "title": "维护租赁记录",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.businessObjectId"
          },
          "size": "2xl",
          "bodyClassName": "px-6 py-2"
        }
      }
    ]
  },
  "data": {
    "search": {},
    "table": {
      "pageSize": 20,
      "service": "crm.setting.CrmHook.BuildBusinessObjectRows",
      "searchFields": [
        "object_no",
        "object_name",
        "object_status"
      ],
      "filterFields": [
        "business_object_type_id"
      ]
    },
    "actionTarget": {
      "businessObjectId": ""
    }
  },
    "state": {
    "dialog": {
      "edit": false
    }
  },
  "action": {}
}
