{
  "page": {
    "name": "沟通群",
    "icon": "messages-square",
    "parent": "crm-customer-manage",
    "sort": 8
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5",
        "children": {
          "toolbar-row": {
            "type": "row",
            "className": "flex-wrap items-center gap-2.5"
          },
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          },
          "feedback-shell": {
            "type": "container"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "name": "群类型",
        "className": "shrink-0",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "icon": "tags"
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.groupType",
            "value": true
          }
        }
      }
    ],
    "toolbar-row": [
      {
        "type": "form-input",
        "placeholder": "搜索群名称、外部群ID、总结...",
        "value": "search.keyword",
        "mode": "search"
      },
      {
        "type": "form-select",
        "placeholder": "群类型",
        "value": "search.group_type_id",
        "mode": "search",
        "option": {
          "model": "crm.NewCommunicationGroupTypeModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200
        }
      },
      {
        "type": "form-select",
        "placeholder": "群状态",
        "value": "search.status",
        "mode": "search"
      },
      {
        "type": "show-button",
        "name": "搜索",
        "meta": {
          "variant": "default",
          "size": "sm",
          "searchSubmit": true
        }
      },
      {
        "type": "show-button",
        "name": "重置",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "to": "/crm/communication_group/list"
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "rowKey": "id",
          "columns": [
            {
              "value": "name",
              "type": "show-base"
            },
            {
              "name": "群类型",
              "value": "group_type.name",
              "type": "show-base"
            },
            {
              "name": "客户",
              "value": "customer.name",
              "type": "show-base"
            },
            {
              "name": "资产",
              "value": "asset.asset_name",
              "type": "show-base"
            },
            {
              "name": "案件流程ID",
              "value": "workflow_instance_id",
              "type": "show-base"
            },
            {
              "name": "群状态",
              "value": "status",
              "type": "show-tag",
              "option": "option.status"
            },
            {
              "value": "established_at",
              "type": "show-date"
            },
            {
              "value": "dissolved_at",
              "type": "show-date"
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "feedback-shell": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.groupType",
          "pageRoute": "/crm/communication_group_type/list",
          "title": "沟通群类型",
          "size": "2xl",
          "bodyClassName": "px-6 py-2"
        }
      }
    ]
  },
  "data": {
    "search": {
      "group_type_id": "",
      "status": ""
    },
    "table": {
      "pageSize": 20,
      "searchFields": [
        "name",
        "external_group_id",
        "summary",
        "remark"
      ],
      "filterFields": [
        "group_type_id",
        "status"
      ]
    }
  },
  "state": {
    "dialog": {
      "groupType": false
    }
  },
  "action": {}
}
