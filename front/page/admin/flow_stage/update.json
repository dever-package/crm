{
  "page": {
    "name": "流程阶段编辑",
    "parent": "crm/flow_stage/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/flow_stage/create",
        "name": "流程阶段新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/flow_stage/update",
        "name": "流程阶段编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-select",
        "value": "form.flow_template_id",
        "mode": "form",
        "option": "/front/route/option?type=model&use=crm.NewFlowTemplateModel&labelField=name&searchFields=name&pageSize=200&order=sort asc,id asc",
        "validate": [
          {
            "type": "required",
            "message": "流程模板不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "value": "form.stage_key",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "阶段标识不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "阶段名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-select",
        "value": "form.default_department_id",
        "mode": "form",
        "option": "/front/route/option?type=model&use=crm.NewDepartmentModel&labelField=name&searchFields=name,code&pageSize=200&order=sort asc,id asc",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-textarea",
        "value": "form.description",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "rows": 3
        }
      },
      {
        "type": "form-textarea",
        "value": "form.position_json",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "rows": 3
        }
      },
      {
        "type": "form-radio",
        "value": "form.status",
        "mode": "form",
        "option": "option.status",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-number",
        "value": "form.sort",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": "",
      "flow_template_id": "",
      "stage_key": "",
      "name": "",
      "description": "",
      "default_department_id": "",
      "position_json": "{}",
      "status": 1,
      "sort": 100
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form"
    }
  }
}
