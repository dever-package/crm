{
  "page": {
    "name": "产品编辑",
    "parent": "crm/product/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/product/create",
        "name": "产品新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/product/update",
        "name": "产品编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "产品名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "value": "form.code",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "产品编码不能为空。"
          },
          {
            "type": "model",
            "except": "$form.id",
            "message": "产品编码已存在。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-select",
        "value": "form.category",
        "mode": "form",
        "option": "option.category",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-select",
        "value": "form.default_signing_business_type",
        "mode": "form",
        "option": "option.default_signing_business_type",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-textarea",
        "value": "form.description",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "rows": 3
        }
      },
      {
        "type": "form-switch",
        "value": "form.need_pm_review",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "trueValue": true,
          "falseValue": false
        }
      },
      {
        "type": "form-switch",
        "value": "form.need_lawyer_review",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "trueValue": true,
          "falseValue": false
        }
      },
      {
        "type": "form-switch",
        "value": "form.need_ala_review",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "trueValue": true,
          "falseValue": false
        }
      },
      {
        "type": "form-switch",
        "value": "form.need_finance_review",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "trueValue": true,
          "falseValue": false
        }
      },
      {
        "type": "form-switch",
        "value": "form.need_contract_review",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "trueValue": true,
          "falseValue": false
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": "",
      "name": "",
      "code": "",
      "category": "consulting",
      "default_signing_business_type": "manual_review",
      "description": "",
      "need_pm_review": true,
      "need_lawyer_review": false,
      "need_ala_review": false,
      "need_finance_review": false,
      "need_contract_review": true
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "crm.setting.CrmHook.BeforeSaveProduct"
      },
      "after": {
        "service": "crm.setting.CrmHook.AfterSaveProduct"
      }
    }
  }
}
