{
  "page": {
    "name": "产品编辑",
    "parent": "crm/product/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/product/create",
        "name": "产品新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/product/update",
        "name": "产品编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "产品名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "value": "form.code",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "产品编码不能为空。"
          },
          {
            "type": "model",
            "except": "$form.id",
            "message": "产品编码已存在。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-select",
        "name": "产品分类",
        "value": "form.category_id",
        "mode": "form",
        "option": {
          "model": "crm.NewProductCategoryModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "filters": {
            "status": 1
          }
        },
        "validate": [
          {
            "type": "required",
            "message": "请选择产品分类。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-select",
        "name": "签约后流程",
        "value": "form.service_workflow_id",
        "placeholder": "不选择则签约流程完成后结束",
        "mode": "form",
        "option": {
          "model": "crm.NewWorkflowModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "filters": {
            "status": 1,
            "default_entry": false
          }
        },
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-textarea",
        "value": "form.description",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "rows": 3
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": "",
      "name": "",
      "code": "",
      "category_id": "",
      "service_workflow_id": "",
      "description": "",
      "status": 1,
      "sort": 100
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "crm.setting.CrmHook.BeforeSaveProduct"
      },
      "after": {
        "service": "crm.setting.CrmHook.AfterSaveProduct"
      }
    }
  }
}
