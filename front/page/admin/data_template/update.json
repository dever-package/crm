{
  "page": {
    "name": "数据模板编辑",
    "parent": "crm/data_template/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/data_template/create",
        "name": "数据模板新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/data_template/update",
        "name": "数据模板编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full",
            "children": {
              "field-page": {
                "type": "container",
                "path": "/crm/data_template/field_list",
                "className": "mt-5"
              }
            }
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-select",
        "value": "form.cate_id",
        "mode": "form",
        "option": {
          "model": "crm.NewDataTemplateCateModel",
          "order": "sort asc,id asc",
          "extraFields": [
            "status",
            "sort",
            "target_table"
          ],
          "filters": {
            "status": "1"
          }
        },
        "validate": [
          {
            "type": "required",
            "message": "模板分类不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[260px]"
        }
      },
      {
        "type": "form-input",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "模板名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      }
    ]
  },
  "data": {
    "form": {
      "_fields": [
        "cate_id",
        "name",
        "fields"
      ],
      "service": "crm.setting.CrmHook.BuildDataTemplateForm",
      "id": "",
      "cate_id": 1,
      "name": "",
      "fields": []
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "crm.setting.CrmHook.BeforeSaveDataTemplate"
      }
    }
  }
}
