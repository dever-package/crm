{
  "page": {
    "name": "流转编辑",
    "parent": "crm/stage_transition/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/stage_transition/create",
        "name": "流转新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/stage_transition/update",
        "name": "流转编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "grid grid-cols-1 gap-x-5 md:grid-cols-2"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-select",
        "name": "来源阶段",
        "value": "form.from_stage_code",
        "mode": "form",
        "option": {
          "model": "crm.NewStageModel",
          "valueField": "code",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "code",
            "name"
          ],
          "filters": {
            "status": "1"
          }
        },
        "validate": [
          {
            "type": "required",
            "message": "来源阶段不能为空。"
          }
        ],
        "meta": {
          "formLayout": "vertical"
        }
      },
      {
        "type": "form-select",
        "name": "目标阶段",
        "value": "form.to_stage_code",
        "mode": "form",
        "option": {
          "model": "crm.NewStageModel",
          "valueField": "code",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "code",
            "name"
          ],
          "filters": {
            "status": "1"
          }
        },
        "validate": [
          {
            "type": "required",
            "message": "目标阶段不能为空。"
          }
        ],
        "meta": {
          "formLayout": "vertical"
        }
      },
      {
        "type": "form-select",
        "name": "触发任务",
        "value": "form.task_id",
        "mode": "form",
        "option": {
          "model": "crm.NewTaskModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "name"
          ],
          "filters": {
            "status": "1"
          }
        },
        "meta": {
          "formLayout": "vertical"
        }
      },
      {
        "type": "form-input",
        "name": "匹配结果",
        "value": "form.result_value",
        "mode": "form",
        "meta": {
          "formLayout": "vertical"
        }
      },
      {
        "type": "form-select",
        "name": "匹配脚本",
        "value": "form.script_id",
        "mode": "form",
        "option": {
          "model": "crm.NewRuleScriptModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "name"
          ],
          "filters": {
            "status": "1"
          }
        },
        "meta": {
          "formLayout": "vertical"
        }
      },
      {
        "type": "form-cascader",
        "name": "条件字段",
        "value": "form.condition_path",
        "mode": "form",
        "placeholder": "不限制条件字段",
        "meta": {
          "formLayout": "vertical",
          "parentField": "parent_id",
          "rootValue": 0,
          "valueField": "id",
          "labelField": "name",
          "leafField": "leaf",
          "placeholder": [
            "选择客户或资产",
            "选择资料模板",
            "选择字段",
            "选择值"
          ],
          "searchPlaceholder": [
            "搜索分类...",
            "搜索模板...",
            "搜索字段...",
            "搜索值..."
          ],
          "controlClassName": "min-w-[12rem]",
          "service": "crm.setting.OptionService.LoadConditionFieldOptions"
        }
      },
      {
        "type": "form-textarea",
        "name": "高级条件JSON",
        "value": "form.condition_json",
        "mode": "form",
        "placeholder": "选择条件字段会自动生成。也可手写：{\"field\":\"customer.fields.audit_status\",\"operator\":\"equals\",\"value\":\"T1\"}",
        "meta": {
          "formLayout": "vertical",
          "rows": 4
        }
      },
      {
        "type": "form-radio",
        "name": "主责模式",
        "value": "form.owner_mode",
        "mode": "form",
        "option": "option.owner_mode",
        "meta": {
          "formLayout": "vertical"
        }
      },
      {
        "type": "form-select",
        "name": "目标部门",
        "value": "form.to_department_id",
        "mode": "form",
        "option": {
          "model": "crm.NewDepartmentModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "code",
            "name"
          ],
          "filters": {
            "status": "1"
          }
        },
        "meta": {
          "formLayout": "vertical"
        }
      },
      {
        "type": "form-select",
        "name": "目标人员",
        "value": "form.to_staff_id",
        "mode": "form",
        "option": {
          "model": "crm.NewStaffModel",
          "labelField": "name",
          "order": "id desc",
          "pageSize": 200,
          "searchFields": [
            "name",
            "phone"
          ],
          "filters": {
            "status": "1"
          }
        },
        "meta": {
          "formLayout": "vertical"
        }
      }
    ]
  },
  "data": {
    "form": {
      "_fields": [
        "from_stage_code",
        "to_stage_code",
        "task_id",
        "result_value",
        "script_id",
        "condition_path",
        "condition_json",
        "owner_mode",
        "to_department_id",
        "to_staff_id"
      ],
      "service": "crm.setting.CrmHook.BuildStageTransitionForm",
      "id": "",
      "from_stage_code": "",
      "to_stage_code": "",
      "task_id": "",
      "result_value": "",
      "script_id": "",
      "condition_path": [],
      "condition_json": "{}",
      "owner_mode": "keep",
      "to_department_id": "",
      "to_staff_id": ""
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "crm.setting.CrmHook.BeforeSaveStageTransition"
      }
    }
  }
}
