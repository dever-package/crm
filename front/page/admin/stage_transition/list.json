{
  "page": {
    "name": "阶段流转",
    "icon": "git-branch",
    "parent": "crm/task/list",
    "type": 2,
    "sort": 5
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5",
        "children": {
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          },
          "feedback-shell": {
            "type": "container"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "name": "新增流转",
        "meta": {
          "variant": "default",
          "size": "sm",
          "icon": "plus"
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.create",
            "value": true
          }
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "savePath": "crm/stage_transition/update",
          "rowKey": "id",
          "columns": [
            {
              "name": "来源阶段",
              "value": "from_stage.name",
              "type": "show-base"
            },
            {
              "name": "任务",
              "value": "task.name",
              "type": "show-base"
            },
            {
              "name": "匹配结果",
              "value": "result_value_display",
              "type": "show-base"
            },
            {
              "name": "目标阶段",
              "value": "to_stage.name",
              "type": "show-base"
            },
            {
              "name": "主责模式",
              "value": "owner_mode_name",
              "type": "show-tag"
            },
            {
              "name": "目标部门",
              "value": "to_department.name",
              "type": "show-base"
            },
            {
              "name": "目标人员",
              "value": "to_staff.name",
              "type": "show-base"
            },
            {
              "name": "状态",
              "value": "status",
              "type": "form-switch",
              "meta": {
                "trueValue": 1,
                "falseValue": 2
              }
            },
            {
              "name": "排序",
              "value": "sort",
              "type": "show-base",
              "editor": "form-number",
              "trigger": "doubleClick"
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "编辑",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.editTransitionId",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.edit",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "feedback-shell": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.edit",
          "pageRoute": "/crm/stage_transition/update",
          "title": "编辑流转",
          "size": "lg",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.editTransitionId"
          },
          "bodyClassName": "px-6 py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.create",
          "pageRoute": "/crm/stage_transition/update",
          "title": "新增流转",
          "size": "lg",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "bodyClassName": "px-6 py-2"
        }
      }
    ]
  },
  "data": {
    "table": {
      "pageSize": 20,
      "service": "crm.setting.CrmHook.BuildStageTransitionRows",
      "searchFields": [
        "from_stage_code",
        "to_stage_code",
        "result_value"
      ]
    },
    "actionTarget": {
      "editTransitionId": ""
    }
  },
  "state": {
    "dialog": {
      "edit": false,
      "create": false
    }
  },
  "action": {}
}
