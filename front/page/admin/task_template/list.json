{
  "page": {
    "name": "任务管理",
    "icon": "list-checks",
    "parent": "crm-flow",
    "sort": 3
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "className": "gap-4",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5 sm:gap-6",
        "children": {
          "content-shell": {
            "type": "container",
            "className": "front-two-pane-layout",
            "children": {
              "category-column": {
                "type": "container",
                "className": "min-w-0"
              },
              "list-column": {
                "type": "container",
                "className": "flex min-w-0 flex-col gap-4",
                "children": {
                  "toolbar-row": {
                    "type": "row",
                    "className": "flex-wrap items-center gap-3"
                  },
                  "table-row": {
                    "type": "container",
                    "className": "overflow-hidden rounded-md border bg-background"
                  }
                }
              }
            }
          },
          "feedback-shell": {
            "type": "container"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page",
        "className": "min-w-0 flex-1"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "name": "新增任务",
        "className": "shrink-0",
        "meta": {
          "variant": "default",
          "size": "sm",
          "icon": "plus"
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.create",
            "value": true
          }
        }
      }
    ],
    "category-column": [
      {
        "type": "show-category-list",
        "id": "crm-task-template-cate",
        "value": "search.cate_id",
        "option": "/front/route/option?type=model&use=crm.NewTaskTemplateCateModel&filterField=status&filterValue=1&order=sort asc,id asc&extraFields=status,sort",
        "meta": {
          "title": "任务分类",
          "description": "左侧选择分类，右侧维护收集任务。",
          "remote": true,
          "defaultFirst": true,
          "queryKey": "cate_id",
          "createButton": {
            "name": "新增分类",
            "icon": "plus",
            "variant": "outline",
            "size": "sm",
            "action": {
              "click": {
                "type": "modal",
                "key": "dialog.createCate",
                "value": true
              }
            }
          },
          "buttons": [
            {
              "icon": "square-pen",
              "variant": "ghost",
              "size": "sm",
              "description": "编辑当前分类",
              "action": {
                "click": [
                  {
                    "type": "data",
                    "key": "actionTarget.editCateId",
                    "value": "$row.id"
                  },
                  {
                    "type": "modal",
                    "key": "dialog.editCate",
                    "value": true
                  }
                ]
              }
            }
          ]
        }
      }
    ],
    "toolbar-row": [
      {
        "type": "form-input",
        "placeholder": "搜索任务名、描述...",
        "value": "search.keyword",
        "mode": "search"
      },
      {
        "type": "show-button",
        "name": "搜索",
        "meta": {
          "variant": "default",
          "size": "sm",
          "searchSubmit": true
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "savePath": "crm/task_template/update",
          "rowKey": "id",
          "columns": [
            {
              "name": "任务名",
              "value": "name",
              "type": "show-base"
            },
            {
              "name": "任务分类",
              "value": "cate.name",
              "type": "show-base"
            },
            {
              "name": "任务描述",
              "value": "description",
              "type": "show-base"
            },
            {
              "name": "状态",
              "value": "status",
              "type": "form-switch",
              "meta": {
                "trueValue": 1,
                "falseValue": 2
              }
            },
            {
              "name": "排序",
              "value": "sort",
              "type": "show-base",
              "editor": "form-number",
              "trigger": "doubleClick"
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "编辑",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.editTaskTemplateId",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.edit",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "feedback-shell": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.createCate",
          "pageRoute": "/crm/task_template_cate/update",
          "title": "新增任务分类",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "size": "sm",
          "bodyClassName": "py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.editCate",
          "pageRoute": "/crm/task_template_cate/update",
          "title": "编辑任务分类",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.editCateId"
          },
          "size": "sm",
          "bodyClassName": "py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.edit",
          "pageRoute": "/crm/task_template/update",
          "title": "编辑任务",
          "size": "xl",
          "width": "64rem",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.editTaskTemplateId"
          },
          "bodyClassName": "px-6 py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.create",
          "pageRoute": "/crm/task_template/update",
          "title": "新增任务",
          "size": "xl",
          "width": "64rem",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "cate_id": "data.search.cate_id"
          },
          "bodyClassName": "px-6 py-2"
        }
      }
    ]
  },
  "data": {
    "search": {
      "cate_id": ""
    },
    "table": {
      "page": 1,
      "pageSize": 20,
      "total": 0,
      "searchFields": [
        "name",
        "description"
      ]
    },
    "actionTarget": {
      "editCateId": "",
      "editTaskTemplateId": ""
    }
  },
  "state": {
    "dialog": {
      "createCate": false,
      "editCate": false,
      "edit": false,
      "create": false
    }
  },
  "action": {}
}
