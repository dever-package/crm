{
  "page": {
    "name": "任务编辑",
    "parent": "crm/task_template/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/task_template/create",
        "name": "任务新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/task_template/update",
        "name": "任务编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-select",
        "value": "form.cate_id",
        "mode": "form",
        "option": "/front/route/option?type=model&use=crm.NewTaskTemplateCateModel&filterField=status&filterValue=1&order=sort asc,id asc",
        "validate": [
          {
            "type": "required",
            "message": "任务分类不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "任务名不能为空。"
          },
          {
            "type": "model",
            "except": "$form.id",
            "message": "该任务名在当前分类下已存在。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-textarea",
        "value": "form.description",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "rows": 3
        }
      },
      {
        "type": "form-array",
        "name": "收集数据",
        "value": "form.fields",
        "mode": "form",
        "info": "选择这个任务需要收集的客户信息或客户资产字段，字段按排序从小到大展示。",
        "meta": {
          "pageRoute": "/crm/task_field/update",
          "addText": "添加收集数据",
          "drag": "sort"
        }
      }
    ]
  },
  "data": {
    "form": {
      "_fields": [
        "cate_id",
        "name",
        "description",
        "fields"
      ],
      "service": "crm.setting.CrmHook.BuildTaskTemplateForm",
      "id": "",
      "cate_id": "",
      "name": "",
      "description": "",
      "fields": []
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "type": "service",
        "use": "crm.setting.CrmHook.BeforeSaveTaskTemplate"
      }
    }
  }
}
