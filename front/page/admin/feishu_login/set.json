{
  "page": {
    "name": "飞书配置",
    "icon": "message-circle",
    "parent": "crm-org-manage",
    "type": 2,
    "sort": 4,
    "auth": [
      {
        "key": "crm/feishu_login/set",
        "name": "飞书配置"
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "form-shell": {
            "type": "container",
            "className": "w-full space-y-5"
          }
        }
      }
    }
  },
  "nodes": {
    "form-shell": [
      {
        "type": "form-input",
        "name": "飞书 AppID",
        "value": "form.feishu_app_id",
        "mode": "form",
        "placeholder": "cli_xxx",
        "validate": [
          {
            "type": "required",
            "message": "飞书 AppID 不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[420px]"
        }
      },
      {
        "type": "form-input",
        "name": "飞书 AppSecret",
        "value": "form.feishu_app_secret",
        "mode": "form",
        "placeholder": "请输入飞书应用 AppSecret",
        "validate": [
          {
            "type": "required",
            "message": "飞书 AppSecret 不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "inputType": "password",
          "controlClassName": "max-w-[420px]"
        }
      },
      {
        "type": "show-title",
        "name": "测试消息",
        "className": "border-t pt-5",
        "meta": {
          "variant": "section"
        }
      },
      {
        "type": "form-select",
        "name": "测试人员",
        "value": "test.staff_id",
        "mode": "form",
        "placeholder": "请选择已绑定飞书人员",
        "option": {
          "service": "crm.setting.OptionService.LoadFeishuBoundStaffOptions",
          "valueField": "id",
          "labelField": "value",
          "pageSize": 200
        },
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[420px]"
        }
      },
      {
        "type": "show-button",
        "name": "发送测试",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "icon": "send",
          "loadingText": "发送中...",
          "successMessage": "测试消息已发送"
        },
        "action": {
          "click": {
            "type": "request",
            "api": "/crm/admin/feishu/test",
            "method": "post",
            "params": "test"
          }
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": 1,
      "feishu_app_id": "",
      "feishu_app_secret": "",
      "model": "crm.NewBasicConfigModel"
    },
    "test": {
      "staff_id": ""
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "upsert": true,
      "params": "form",
      "before": {
        "service": "crm.setting.CrmHook.BeforeSaveBasicConfig"
      },
      "model": "crm.NewBasicConfigModel"
    }
  }
}
