{
  "page": {
    "name": "任务处理",
    "parent": "crm/resource_task/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/resource_task/update",
        "name": "任务处理",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "value": "form.task_name",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-radio",
        "value": "form.status",
        "mode": "form",
        "option": "option.status",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-radio",
        "value": "form.executor_mode",
        "mode": "form",
        "option": "option.executor_mode",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-select",
        "value": "form.assignee_department_id",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-select",
        "value": "form.assignee_staff_id",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "value": "form.result_value",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-textarea",
        "value": "form.result_text",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "rows": 4
        }
      },
      {
        "type": "form-textarea",
        "value": "form.output_json",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "rows": 4
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": "",
      "task_name": "",
      "status": "pending",
      "executor_mode": "department",
      "assignee_department_id": "",
      "assignee_staff_id": "",
      "result_value": "",
      "result_text": "",
      "output_json": "{}"
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form"
    }
  }
}
