{
  "page": {
    "name": "阶段任务",
    "icon": "route",
    "parent": "crm-business-config",
    "sort": 3
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "className": "gap-4",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5 sm:gap-6",
        "children": {
          "content-shell": {
            "type": "container",
            "className": "front-two-pane-layout",
            "children": {
              "stage-column": {
                "type": "container",
                "className": "min-w-0"
              },
              "task-column": {
                "type": "container",
                "className": "flex min-w-0 flex-col gap-4",
                "children": {
                  "toolbar-row": {
                    "type": "row",
                    "className": "flex-wrap items-center gap-2.5"
                  },
                  "table-row": {
                    "type": "container",
                    "className": "overflow-hidden rounded-md border bg-background"
                  }
                }
              }
            }
          },
          "feedback-shell": {
            "type": "container"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page",
        "className": "min-w-0 flex-1"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "name": "新增任务",
        "className": "shrink-0",
        "meta": {
          "variant": "default",
          "size": "sm",
          "icon": "plus"
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.create",
            "value": true
          }
        }
      }
    ],
    "stage-column": [
      {
        "type": "show-category-list",
        "id": "crm-stage-list",
        "value": "search.stage_id",
        "option": {
          "service": "crm.setting.OptionService.LoadStageOptions",
          "valueField": "id",
          "labelField": "name"
        },
        "meta": {
          "title": "阶段列表",
          "description": "左侧选择阶段，右侧维护该阶段下的任务。",
          "remote": true,
          "defaultFirst": true,
          "emptyText": "暂无阶段。",
          "queryKey": "stage_id",
          "labelField": "name",
          "createButton": {
            "name": "新增阶段",
            "icon": "plus",
            "variant": "outline",
            "size": "sm",
            "action": {
              "click": {
                "type": "modal",
                "key": "dialog.createStage",
                "value": true
              }
            }
          },
          "buttons": [
            {
              "icon": "square-pen",
              "variant": "ghost",
              "size": "sm",
              "description": "编辑当前阶段",
              "action": {
                "click": [
                  {
                    "type": "data",
                    "key": "actionTarget.stageId",
                    "value": "$row.id"
                  },
                  {
                    "type": "modal",
                    "key": "dialog.editStage",
                    "value": true
                  }
                ]
              }
            }
          ]
        }
      }
    ],
    "toolbar-row": [
      {
        "type": "form-input",
        "placeholder": "搜索任务名称...",
        "value": "search.keyword",
        "mode": "search"
      },
      {
        "type": "show-button",
        "name": "搜索",
        "meta": {
          "variant": "default",
          "size": "sm",
          "searchSubmit": true
        }
      },
      {
        "type": "show-button",
        "name": "重置",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "to": "/crm/task/list"
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "savePath": "crm/task/update",
          "rowKey": "id",
          "columns": [
            {
              "name": "任务名称",
              "value": "name",
              "type": "show-base"
            },
            {
              "name": "任务动作",
              "value": "task_type_name",
              "type": "show-tag"
            },
            {
              "name": "触发方式",
              "value": "trigger_type_name",
              "type": "show-base"
            },
            {
              "name": "完成后进入",
              "value": "next_stage_name",
              "type": "show-base"
            },
            {
              "name": "任务积分",
              "value": "task_points",
              "type": "show-base"
            },
            {
              "name": "状态",
              "value": "status",
              "type": "form-switch",
              "meta": {
                "trueValue": 1,
                "falseValue": 2
              }
            },
            {
              "name": "排序",
              "value": "sort",
              "type": "show-base",
              "editor": "form-number",
              "trigger": "doubleClick"
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "编辑",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.taskId",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.edit",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "feedback-shell": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.createStage",
          "pageRoute": "/crm/stage/update",
          "title": "新增阶段",
          "assistant": false,
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "size": "sm",
          "bodyClassName": "py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.editStage",
          "pageRoute": "/crm/stage/update",
          "title": "编辑阶段",
          "assistant": false,
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.stageId"
          },
          "size": "sm",
          "bodyClassName": "py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.edit",
          "pageRoute": "/crm/task/update",
          "title": "编辑任务",
          "size": "lg",
          "width": "56rem",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.taskId"
          },
          "bodyClassName": "px-6 py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.create",
          "pageRoute": "/crm/task/update",
          "title": "新增任务",
          "size": "lg",
          "width": "56rem",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "stage_id": "data.search.stage_id"
          },
          "bodyClassName": "px-6 py-2"
        }
      }
    ]
  },
  "data": {
    "search": {
      "stage_id": 1,
      "keyword": ""
    },
    "table": {
      "pageSize": 20,
      "service": "crm.setting.CrmHook.BuildTaskRows",
      "defaultFilters": {
        "stage_id": 1
      },
      "searchFields": [
        "name"
      ],
      "filterFields": [
        "stage_id"
      ]
    },
    "actionTarget": {
      "stageId": "",
      "taskId": ""
    }
  },
  "state": {
    "dialog": {
      "createStage": false,
      "editStage": false,
      "edit": false,
      "create": false
    }
  },
  "action": {}
}
