{
  "page": {
    "name": "协作子任务",
    "parent": "crm/task/update",
    "type": 2
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "name": "子任务名称",
        "value": "form.name",
        "mode": "form",
        "placeholder": "例如：NPL首呼",
        "validate": [
          {
            "type": "required",
            "message": "子任务名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-select",
        "name": "目标部门",
        "value": "form.department_id",
        "mode": "form",
        "option": {
          "model": "crm.NewDepartmentModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "code",
            "name"
          ],
          "filters": {
            "status": "1"
          }
        },
        "validate": [
          {
            "type": "required",
            "message": "目标部门不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "clearOnChange": [
            "form.staff_id"
          ]
        }
      },
      {
        "type": "form-select",
        "name": "处理人员",
        "value": "form.staff_id",
        "mode": "form",
        "placeholder": "不选择人员",
        "option": {
          "service": "crm.setting.OptionService.LoadTaskCollaborationStaffOptions",
          "valueField": "id",
          "labelField": "value"
        },
        "info": "不选择人员时，手动派单需在工作台选择目标部门内的处理人员；选择人员后，工作台不可再调整。",
        "meta": {
          "formLayout": "horizontal",
          "placeholder": "不选择人员",
          "optionParams": {
            "parentId": "form.department_id"
          }
        }
      },
      {
        "type": "form-select",
        "name": "处理资料模板",
        "value": "form.form_id",
        "mode": "form",
        "option": {
          "model": "crm.NewFormModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "name"
          ],
          "filters": {
            "status": "1"
          }
        },
        "meta": {
          "formLayout": "horizontal",
          "placeholder": "完成子任务时需要填写的资料"
        }
      },
      {
        "type": "form-number",
        "name": "任务积分",
        "value": "form.task_points",
        "mode": "form",
        "info": "完成该协作子任务后获得的积分；为空或 0 时不计分。",
        "meta": {
          "formLayout": "horizontal",
          "min": 0,
          "step": 0.5
        }
      },
      {
        "type": "form-radio",
        "name": "完成方式",
        "value": "form.completion_mode",
        "mode": "form",
        "option": [
          {
            "id": "submit",
            "value": "提交即完成"
          },
          {
            "id": "manual",
            "value": "可多次保存，手动完成"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-switch",
        "name": "必做",
        "value": "form.required",
        "mode": "form",
        "info": "开启后，该子任务未完成时不会允许主任务确认完成；关闭后仅作为辅助待办，不阻塞主流程。",
        "meta": {
          "formLayout": "horizontal",
          "trueValue": true,
          "falseValue": false
        }
      }
    ]
  },
  "data": {
    "form": {
      "name": "",
      "department_id": "",
      "staff_id": "",
      "form_id": "",
      "task_points": 0,
      "completion_mode": "submit",
      "required": true,
      "sort": 100
    }
  },
  "state": {},
  "action": {}
}
