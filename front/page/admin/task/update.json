{
  "page": {
    "name": "任务编辑",
    "parent": "crm/workflow/list",
    "auth": [
      {
        "key": "crm/task/create",
        "name": "任务新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/task/update",
        "name": "任务编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "name": "任务名称",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "任务名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-radio",
        "name": "任务类型",
        "value": "form.task_type",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "任务类型不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "clearOnChange": [
            "form.form_id",
            "form.script_id"
          ]
        }
      },
      {
        "type": "form-select",
        "name": "资料表单",
        "value": "form.form_id",
        "mode": "form",
        "option": {
          "model": "crm.NewFormModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "name"
          ],
          "filters": {
            "status": 1
          }
        },
        "meta": {
          "formLayout": "horizontal",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "form"
            }
          ]
        }
      },
      {
        "type": "form-select",
        "name": "核验规则",
        "value": "form.script_id",
        "mode": "form",
        "option": {
          "model": "crm.NewRuleScriptModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "name"
          ],
          "filters": {
            "status": 1
          }
        },
        "meta": {
          "formLayout": "horizontal",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "rule"
            }
          ]
        }
      },
      {
        "type": "form-switch",
        "name": "必做任务",
        "value": "form.required",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "trueValue": true,
          "falseValue": false
        }
      },
      {
        "type": "form-radio",
        "name": "负责方式",
        "value": "form.assignee_mode",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "负责方式不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "clearOnChange": [
            "form.assignee_department_id"
          ]
        }
      },
      {
        "type": "form-select",
        "name": "负责部门",
        "value": "form.assignee_department_id",
        "mode": "form",
        "option": {
          "model": "crm.NewDepartmentModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "name"
          ],
          "filters": {
            "status": 1
          }
        },
        "meta": {
          "formLayout": "horizontal",
          "hiddenWhen": [
            {
              "path": "form.assignee_mode",
              "operator": "equals",
              "value": "stage"
            }
          ]
        }
      },
      {
        "type": "form-number",
        "name": "办理期限（天）",
        "value": "form.due_days",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "min": 0,
          "step": 1
        }
      },
      {
        "type": "form-number",
        "name": "排序",
        "value": "form.sort",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "min": 0,
          "step": 10
        }
      },
      {
        "type": "form-switch",
        "name": "启用",
        "value": "form.status",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "trueValue": 1,
          "falseValue": 2
        }
      }
    ]
  },
  "data": {
    "form": {
      "_fields": [
        "stage_id",
        "name",
        "task_type",
        "required",
        "assignee_mode",
        "assignee_department_id",
        "form_id",
        "script_id",
        "due_days",
        "sort",
        "status"
      ],
      "stage_id": "",
      "name": "",
      "task_type": "todo",
      "required": true,
      "assignee_mode": "stage",
      "assignee_department_id": "",
      "form_id": "",
      "script_id": "",
      "due_days": 0,
      "sort": 100,
      "status": 1
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "crm.setting.CrmHook.BeforeSaveTask"
      }
    }
  }
}
