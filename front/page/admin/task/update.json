{
  "page": {
    "name": "任务编辑",
    "parent": "crm/task/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/task/create",
        "name": "任务新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/task/update",
        "name": "任务编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-select",
        "name": "所属阶段",
        "value": "form.stage_id",
        "mode": "form",
        "option": "/front/route/option?type=service&use=crm.setting.OptionService.LoadStageOptions&valueField=id&labelField=display_name",
        "validate": [
          {
            "type": "required",
            "message": "所属阶段不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "name": "任务名称",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "任务名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-radio",
        "name": "任务动作",
        "value": "form.task_type",
        "mode": "form",
        "option": [
          {
            "id": "create",
            "value": "创建资料"
          },
          {
            "id": "form",
            "value": "填写资料"
          },
          {
            "id": "assign",
            "value": "分配"
          },
          {
            "id": "collaborate",
            "value": "协作任务"
          },
          {
            "id": "decision",
            "value": "决策"
          },
          {
            "id": "booking",
            "value": "资源预定"
          }
        ],
        "validate": [
          {
            "type": "required",
            "message": "任务动作不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "clearOnChange": [
            "form.form_id",
            "form.script_id",
            "form.decision_result_field_path",
            "form.trigger_task_id",
            "form.assign_department_ids",
            "form.collaboration_items",
            "form.collaboration_complete_mode",
            "form.booking_resource_cate_id",
            "form.booking_need_confirm"
          ]
        }
      },
      {
        "type": "form-radio",
        "name": "触发方式",
        "value": "form.trigger_type",
        "mode": "form",
        "option": "option.trigger_type",
        "meta": {
          "formLayout": "horizontal",
          "clearOnChange": [
            "form.trigger_task_id"
          ]
        }
      },
      {
        "type": "form-select",
        "name": "触发任务",
        "value": "form.trigger_task_id",
        "mode": "form",
        "option": "/front/route/option?type=model&use=crm.NewTaskModel&filterField=status&filterValue=1&labelField=name&searchFields=name&order=sort asc,id asc&pageSize=200",
        "meta": {
          "formLayout": "horizontal",
          "placeholder": "选择哪个任务执行后自动触发",
          "hiddenWhen": [
            {
              "path": "form.trigger_type",
              "operator": "notEquals",
              "value": "after_task"
            }
          ]
        }
      },
      {
        "type": "form-select",
        "name": "资料模板",
        "value": "form.form_id",
        "mode": "form",
        "option": "/front/route/option?type=model&use=crm.NewFormModel&filterField=status&filterValue=1&labelField=name&searchFields=name&order=sort asc,id asc&pageSize=200",
        "meta": {
          "formLayout": "horizontal",
          "placeholder": "选择任务需要填写的资料模板",
          "hiddenCondition": "all",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "create"
            },
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "form"
            }
          ]
        }
      },
      {
        "type": "form-array",
        "name": "协作子任务",
        "value": "form.collaboration_items",
        "mode": "form",
        "info": "生成多个部门/人员的并行待办；派单时间使用本次协作任务操作日志的创建时间。",
        "meta": {
          "pageRoute": "/crm/task/collaboration_item",
          "addText": "添加子任务",
          "drag": "sort",
          "itemName": "协作子任务",
          "valueFormat": "json",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "collaborate"
            }
          ]
        }
      },
      {
        "type": "form-radio",
        "name": "完成规则",
        "value": "form.collaboration_complete_mode",
        "mode": "form",
        "option": [
          {
            "id": "all",
            "value": "全部必做完成后流转"
          },
          {
            "id": "any",
            "value": "任意完成后流转"
          },
          {
            "id": "manual",
            "value": "仅生成待办不自动流转"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "collaborate"
            }
          ]
        }
      },
      {
        "type": "form-select",
        "name": "资源分类",
        "value": "form.booking_resource_cate_id",
        "mode": "form",
        "option": "/front/route/option?type=model&use=crm.NewPublicResourceCateModel&filterField=status&filterValue=1&labelField=name&searchFields=name&order=sort asc,id asc&pageSize=200",
        "validate": [
          {
            "type": "required",
            "message": "资源分类不能为空。",
            "when": [
              {
                "path": "form.task_type",
                "operator": "equals",
                "value": "booking"
              }
            ]
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "placeholder": "选择这个任务可预定的资源分类",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "booking"
            }
          ]
        }
      },
      {
        "type": "form-radio",
        "name": "需要确认",
        "value": "form.booking_need_confirm",
        "mode": "form",
        "option": [
          {
            "id": 0,
            "value": "否"
          },
          {
            "id": 1,
            "value": "是"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "booking"
            }
          ]
        }
      },
      {
        "type": "form-radio",
        "name": "派单方式",
        "value": "form.assign_mode",
        "mode": "form",
        "option": [
          {
            "id": "staff",
            "value": "选择人员"
          },
          {
            "id": "department",
            "value": "选择部门"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "assign"
            }
          ]
        }
      },
      {
        "type": "form-select",
        "name": "可选部门",
        "value": "form.assign_department_ids",
        "mode": "form",
        "option": "/front/route/option?type=model&use=crm.NewDepartmentModel&filterField=status&filterValue=1&labelField=name&searchFields=code,name&order=sort asc,id asc&pageSize=200",
        "validate": [
          {
            "type": "required",
            "message": "可选部门不能为空。",
            "when": [
              {
                "path": "form.task_type",
                "operator": "equals",
                "value": "assign"
              }
            ]
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "multiple": true,
          "placeholder": "请选择这个任务允许派单的部门",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "assign"
            }
          ]
        }
      },
      {
        "type": "form-select",
        "name": "脚本规则",
        "value": "form.script_id",
        "mode": "form",
        "option": "/front/route/option?type=model&use=crm.NewRuleScriptModel&filterField=status&filterValue=1&labelField=name&searchFields=name&order=sort asc,id asc&pageSize=200",
        "validate": [
          {
            "type": "required",
            "message": "自动触发的决策任务必须选择脚本规则。",
            "when": [
              {
                "path": "form.task_type",
                "operator": "equals",
                "value": "decision"
              },
              {
                "path": "form.trigger_type",
                "operator": "notEquals",
                "value": "manual"
              }
            ]
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "placeholder": "选择自动触发时使用的脚本规则",
          "hiddenCondition": "any",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "decision"
            },
            {
              "path": "form.trigger_type",
              "operator": "equals",
              "value": "manual"
            }
          ]
        }
      },
      {
        "type": "form-cascader",
        "name": "结果写入字段",
        "value": "form.decision_result_field_path",
        "mode": "form",
        "placeholder": "选择决策结果要写入的条件字段",
        "validate": [
          {
            "type": "required",
            "message": "决策任务必须选择结果写入字段。",
            "when": [
              {
                "path": "form.task_type",
                "operator": "equals",
                "value": "decision"
              }
            ]
          }
        ],
        "meta": {
          "api": "/front/route/option",
          "type": "service",
          "use": "crm.setting.OptionService.LoadDecisionResultFieldOptions",
          "formLayout": "horizontal",
          "parentField": "parent_id",
          "rootValue": 0,
          "valueField": "id",
          "labelField": "name",
          "leafField": "leaf",
          "placeholder": [
            "选择客户或资产",
            "选择资料模板",
            "选择条件字段"
          ],
          "searchPlaceholder": [
            "搜索分类...",
            "搜索模板...",
            "搜索字段..."
          ],
          "controlClassName": "min-w-[12rem]",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "decision"
            }
          ]
        }
      },
      {
        "type": "form-select",
        "name": "完成后阶段",
        "value": "form.next_stage_code",
        "mode": "form",
        "option": "/front/route/option?type=service&use=crm.setting.OptionService.LoadStageOptions&valueField=code&labelField=display_name",
        "meta": {
          "formLayout": "horizontal",
          "placeholder": "不自动流转"
        }
      },
      {
        "type": "form-cascader",
        "name": "显示条件",
        "value": "form.visible_condition_path",
        "mode": "form",
        "placeholder": "不限制显示条件",
        "meta": {
          "api": "/front/route/option",
          "type": "service",
          "use": "crm.setting.OptionService.LoadTaskVisibleConditionOptions",
          "formLayout": "horizontal",
          "parentField": "parent_id",
          "rootValue": 0,
          "valueField": "id",
          "labelField": "name",
          "leafField": "leaf",
          "placeholder": [
            "选择客户或资产",
            "选择资料模板",
            "选择字段",
            "选择值"
          ],
          "searchPlaceholder": [
            "搜索分类...",
            "搜索模板...",
            "搜索字段...",
            "搜索值..."
          ],
          "controlClassName": "min-w-[12rem]"
        }
      }
    ]
  },
  "data": {
    "form": {
      "_fields": [
        "stage_id",
        "name",
        "task_type",
        "trigger_type",
        "trigger_task_id",
        "next_stage_code",
        "config_json",
        "form_id",
        "assign_mode",
        "assign_department_ids",
        "collaboration_items",
        "collaboration_complete_mode",
        "booking_resource_cate_id",
        "booking_need_confirm",
        "script_id",
        "decision_result_field_path",
        "visible_condition_path"
      ],
      "service": "crm.setting.CrmHook.BuildTaskForm",
      "id": "",
      "stage_id": "",
      "name": "",
      "task_type": "form",
      "trigger_type": "manual",
      "trigger_task_id": "",
      "next_stage_code": "",
      "config_json": "{}",
      "form_id": "",
      "assign_mode": "staff",
      "assign_department_ids": [],
      "collaboration_items": [],
      "collaboration_complete_mode": "all",
      "booking_resource_cate_id": 1,
      "booking_need_confirm": 0,
      "script_id": "",
      "decision_result_field_path": [],
      "visible_condition_path": []
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "type": "service",
        "use": "crm.setting.CrmHook.BeforeSaveTask"
      },
      "after": {
        "type": "service",
        "use": "crm.setting.CrmHook.AfterSaveTask"
      }
    }
  }
}
