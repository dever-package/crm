{
  "page": {
    "name": "任务编辑",
    "parent": "crm/task/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/task/create",
        "name": "任务新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/task/update",
        "name": "任务编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-select",
        "name": "所属阶段",
        "value": "form.stage_id",
        "mode": "form",
        "option": {
          "service": "crm.setting.OptionService.LoadStageOptions",
          "valueField": "id",
          "labelField": "display_name"
        },
        "validate": [
          {
            "type": "required",
            "message": "所属阶段不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "name": "任务名称",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "任务名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-radio",
        "name": "任务动作",
        "value": "form.task_type",
        "mode": "form",
        "option": [
          {
            "id": "create",
            "value": "创建资料"
          },
          {
            "id": "form",
            "value": "填写资料"
          },
          {
            "id": "assign",
            "value": "分配"
          },
          {
            "id": "collaborate",
            "value": "协作任务"
          },
          {
            "id": "decision",
            "value": "决策"
          },
          {
            "id": "booking",
            "value": "资源预定"
          }
        ],
        "validate": [
          {
            "type": "required",
            "message": "任务动作不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "clearOnChange": [
            "form.form_id",
            "form.script_id",
            "form.decision_result_field_path",
            "form.trigger_task_id",
            "form.assign_department_ids",
            "form.auto_assign_department_id",
            "form.auto_assign_staff_id",
            "form.collaboration_items",
            "form.collaboration_complete_mode",
            "form.completion_mode",
            "form.booking_resource_cate_id",
            "form.booking_need_confirm"
          ]
        }
      },
      {
        "type": "form-radio",
        "name": "触发方式",
        "value": "form.trigger_type",
        "mode": "form",
        "option": "option.trigger_type",
        "meta": {
          "formLayout": "horizontal",
          "info": "任务后触发会在来源任务执行成功后立即触发；协作任务会在派单成功后触发，不会等待协作子任务完成。需要等待律师、财务等子任务完成后再继续流程时，请使用协作任务的完成规则和完成后阶段。",
          "optionFilter": [
            {
              "field": "id",
              "path": "form.task_type",
              "map": {
                "assign": [
                  "manual",
                  "after_task",
                  "on_stage_enter"
                ],
                "collaborate": [
                  "manual",
                  "after_task",
                  "on_stage_enter"
                ],
                "decision": [
                  "manual",
                  "after_task",
                  "on_stage_enter"
                ],
                "create": [
                  "manual"
                ],
                "form": [
                  "manual"
                ],
                "booking": [
                  "manual"
                ]
              }
            }
          ],
          "clearOnChange": [
            "form.trigger_task_id"
          ]
        }
      },
      {
        "type": "form-number",
        "name": "任务积分",
        "value": "form.task_points",
        "mode": "form",
        "info": "任务真正完成后给操作人员增加的积分；保存进度不计分，填 0 不生成积分流水。",
        "meta": {
          "formLayout": "horizontal",
          "min": 0,
          "step": 1,
          "placeholder": "0"
        }
      },
      {
        "type": "form-select",
        "name": "触发任务",
        "value": "form.trigger_task_id",
        "mode": "form",
        "option": {
          "model": "crm.NewTaskModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "name"
          ],
          "filters": {
            "status": "1"
          }
        },
        "meta": {
          "formLayout": "horizontal",
          "placeholder": "选择哪个任务执行成功后立即触发",
          "hiddenWhen": [
            {
              "path": "form.trigger_type",
              "operator": "notEquals",
              "value": "after_task"
            }
          ]
        }
      },
      {
        "type": "form-select",
        "name": "资料模板",
        "value": "form.form_id",
        "mode": "form",
        "option": {
          "model": "crm.NewFormModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "name"
          ],
          "filters": {
            "status": "1"
          }
        },
        "meta": {
          "formLayout": "horizontal",
          "placeholder": "选择任务需要填写的资料模板",
          "hiddenCondition": "all",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "create"
            },
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "form"
            }
          ]
        }
      },
      {
        "type": "form-array",
        "name": "协作子任务",
        "value": "form.collaboration_items",
        "mode": "form",
        "info": "生成多个部门/人员的并行待办；后台未指定人员时，工作台派单人需要选择目标部门内的处理人员。必做子任务会参与协作完成规则。",
        "meta": {
          "pageRoute": "/crm/task/collaboration_item",
          "addText": "添加子任务",
          "drag": "sort",
          "itemName": "协作子任务",
          "valueFormat": "json",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "collaborate"
            }
          ]
        }
      },
      {
        "type": "form-radio",
        "name": "完成规则",
        "value": "form.collaboration_complete_mode",
        "mode": "form",
        "option": [
          {
            "id": "all",
            "value": "全部必做完成后流转"
          },
          {
            "id": "any",
            "value": "任一子任务完成后流转"
          },
          {
            "id": "manual",
            "value": "只派单，不自动流转"
          }
        ],
        "info": "例如 PM 派律师/财务处理，完成规则选择“全部必做完成后流转”，完成后阶段选择下一个 PM 阶段；PM 后续任务应放在该下一个阶段。",
        "meta": {
          "formLayout": "horizontal",
          "clearOnChange": [
            "form.auto_assign_staff_id"
          ],
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "collaborate"
            }
          ]
        }
      },
      {
        "type": "form-select",
        "name": "资源分类",
        "value": "form.booking_resource_cate_id",
        "mode": "form",
        "option": {
          "model": "crm.NewPublicResourceCateModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "name"
          ],
          "filters": {
            "status": "1"
          }
        },
        "validate": [
          {
            "type": "required",
            "message": "资源分类不能为空。",
            "when": [
              {
                "path": "form.task_type",
                "operator": "equals",
                "value": "booking"
              }
            ]
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "placeholder": "选择这个任务可预定的资源分类",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "booking"
            }
          ]
        }
      },
      {
        "type": "form-radio",
        "name": "需要确认",
        "value": "form.booking_need_confirm",
        "mode": "form",
        "option": [
          {
            "id": 0,
            "value": "否"
          },
          {
            "id": 1,
            "value": "是"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "booking"
            }
          ]
        }
      },
      {
        "type": "form-radio",
        "name": "派单方式",
        "value": "form.assign_mode",
        "mode": "form",
        "option": [
          {
            "id": "staff",
            "value": "选择人员"
          },
          {
            "id": "department",
            "value": "选择部门"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "assign"
            }
          ]
        }
      },
      {
        "type": "form-select",
        "name": "可选部门",
        "value": "form.assign_department_ids",
        "mode": "form",
        "option": {
          "model": "crm.NewDepartmentModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "code",
            "name"
          ],
          "filters": {
            "status": "1"
          }
        },
        "validate": [
          {
            "type": "required",
            "message": "可选部门不能为空。",
            "when": [
              {
                "path": "form.task_type",
                "operator": "equals",
                "value": "assign"
              }
            ]
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "multiple": true,
          "placeholder": "请选择这个任务允许派单的部门",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "assign"
            }
          ]
        }
      },
      {
        "type": "form-select",
        "name": "自动分配部门",
        "value": "form.auto_assign_department_id",
        "mode": "form",
        "option": {
          "model": "crm.NewDepartmentModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "code",
            "name"
          ],
          "filters": {
            "status": "1"
          }
        },
        "validate": [
          {
            "type": "required",
            "message": "自动触发的分配任务必须选择自动分配部门。",
            "when": [
              {
                "path": "form.task_type",
                "operator": "equals",
                "value": "assign"
              },
              {
                "path": "form.trigger_type",
                "operator": "notEquals",
                "value": "manual"
              }
            ]
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "placeholder": "自动触发时分配到的部门",
          "hiddenCondition": "any",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "assign"
            },
            {
              "path": "form.trigger_type",
              "operator": "equals",
              "value": "manual"
            }
          ],
          "clearOnChange": [
            "form.auto_assign_staff_id"
          ]
        }
      },
      {
        "type": "form-select",
        "name": "自动分配人员",
        "value": "form.auto_assign_staff_id",
        "mode": "form",
        "placeholder": "不选择则使用部门负责人",
        "option": {
          "model": "crm.NewStaffModel",
          "labelField": "name",
          "parentField": "department_id",
          "order": "id asc",
          "pageSize": 200,
          "searchFields": [
            "name",
            "phone"
          ],
          "filters": {
            "status": "1"
          }
        },
        "meta": {
          "formLayout": "horizontal",
          "placeholder": "不选择则使用部门负责人",
          "optionParams": {
            "parentId": "form.auto_assign_department_id"
          },
          "hiddenCondition": "any",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "assign"
            },
            {
              "path": "form.trigger_type",
              "operator": "equals",
              "value": "manual"
            },
            {
              "path": "form.assign_mode",
              "operator": "equals",
              "value": "department"
            }
          ]
        }
      },
      {
        "type": "form-select",
        "name": "脚本规则",
        "value": "form.script_id",
        "mode": "form",
        "option": {
          "model": "crm.NewRuleScriptModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "name"
          ],
          "filters": {
            "status": "1"
          }
        },
        "validate": [
          {
            "type": "required",
            "message": "自动触发的决策任务必须选择脚本规则。",
            "when": [
              {
                "path": "form.task_type",
                "operator": "equals",
                "value": "decision"
              },
              {
                "path": "form.trigger_type",
                "operator": "notEquals",
                "value": "manual"
              }
            ]
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "placeholder": "选择自动触发时使用的脚本规则",
          "hiddenCondition": "any",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "decision"
            },
            {
              "path": "form.trigger_type",
              "operator": "equals",
              "value": "manual"
            }
          ]
        }
      },
      {
        "type": "form-cascader",
        "name": "结果写入字段",
        "value": "form.decision_result_field_path",
        "mode": "form",
        "placeholder": "选择决策结果要写入的条件字段",
        "validate": [
          {
            "type": "required",
            "message": "决策任务必须选择结果写入字段。",
            "when": [
              {
                "path": "form.task_type",
                "operator": "equals",
                "value": "decision"
              }
            ]
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "parentField": "parent_id",
          "rootValue": 0,
          "valueField": "id",
          "labelField": "name",
          "leafField": "leaf",
          "placeholder": [
            "选择客户或资产",
            "选择资料模板",
            "选择条件字段"
          ],
          "searchPlaceholder": [
            "搜索分类...",
            "搜索模板...",
            "搜索字段..."
          ],
          "controlClassName": "min-w-[12rem]",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "decision"
            }
          ],
          "service": "crm.setting.OptionService.LoadDecisionResultFieldOptions"
        }
      },
      {
        "type": "form-select",
        "name": "完成后阶段",
        "value": "form.next_stage_code",
        "mode": "form",
        "option": {
          "service": "crm.setting.OptionService.LoadStageOptions",
          "valueField": "code",
          "labelField": "display_name"
        },
        "info": "协作任务会在完成规则满足后流转到该阶段；若要 PM 等律师/财务完成后继续，请选择下一个 PM 阶段。普通任务则在任务完成后流转。",
        "meta": {
          "formLayout": "horizontal",
          "placeholder": "不自动流转"
        }
      },
      {
        "type": "form-radio",
        "name": "完成方式",
        "value": "form.completion_mode",
        "mode": "form",
        "option": [
          {
            "id": "submit",
            "value": "提交即完成"
          },
          {
            "id": "manual",
            "value": "可多次保存，手动完成"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "form"
            }
          ]
        }
      },
      {
        "type": "form-cascader",
        "name": "显示条件",
        "value": "form.visible_condition_path",
        "mode": "form",
        "placeholder": "不限制显示条件",
        "meta": {
          "formLayout": "horizontal",
          "parentField": "parent_id",
          "rootValue": 0,
          "valueField": "id",
          "labelField": "name",
          "leafField": "leaf",
          "placeholder": [
            "选择客户或资产",
            "选择资料模板",
            "选择字段",
            "选择值"
          ],
          "searchPlaceholder": [
            "搜索分类...",
            "搜索模板...",
            "搜索字段...",
            "搜索值..."
          ],
          "controlClassName": "min-w-[12rem]",
          "service": "crm.setting.OptionService.LoadTaskVisibleConditionOptions"
        }
      }
    ]
  },
  "data": {
    "form": {
      "_fields": [
        "stage_id",
        "name",
        "task_type",
        "trigger_type",
        "trigger_task_id",
        "task_points",
        "next_stage_code",
        "config_json",
        "form_id",
        "assign_mode",
        "assign_department_ids",
        "auto_assign_department_id",
        "auto_assign_staff_id",
        "collaboration_items",
        "collaboration_complete_mode",
        "completion_mode",
        "booking_resource_cate_id",
        "booking_need_confirm",
        "script_id",
        "decision_result_field_path",
        "visible_condition_path"
      ],
      "service": "crm.setting.CrmHook.BuildTaskForm",
      "id": "",
      "stage_id": "",
      "name": "",
      "task_type": "form",
      "trigger_type": "manual",
      "trigger_task_id": "",
      "task_points": 0,
      "next_stage_code": "",
      "config_json": "{}",
      "form_id": "",
      "assign_mode": "staff",
      "assign_department_ids": [],
      "auto_assign_department_id": "",
      "auto_assign_staff_id": "",
      "collaboration_items": [],
      "collaboration_complete_mode": "all",
      "completion_mode": "submit",
      "booking_resource_cate_id": 1,
      "booking_need_confirm": 0,
      "script_id": "",
      "decision_result_field_path": [],
      "visible_condition_path": []
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "crm.setting.CrmHook.BeforeSaveTask"
      }
    }
  }
}
