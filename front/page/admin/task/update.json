{
  "page": {
    "name": "任务编辑",
    "parent": "crm/workflow/list",
    "auth": [
      {
        "key": "crm/task/create",
        "name": "任务新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/task/update",
        "name": "任务编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "tabs-row": {
            "type": "container",
            "className": "mb-4"
          },
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "tabs-row": [
      {
        "type": "nav-tab",
        "meta": {
          "target": "state.currentTab",
          "variant": "line",
          "tabs": [
            {
              "label": "基础信息",
              "value": "basic"
            },
            {
              "label": "流程控制",
              "value": "flow"
            },
            {
              "label": "业务能力",
              "value": "capability"
            }
          ]
        }
      }
    ],
    "dialog-shell": [
      {
        "type": "form-input",
        "name": "任务名称",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "任务名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "basic"
        }
      },
      {
        "type": "form-radio",
        "name": "任务类型",
        "value": "form.task_type",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "任务类型不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "basic",
          "clearOnChange": [
            "form.form_id",
            "form.script_id",
            "form.meeting_enabled",
            "form.customer_follow_enabled"
          ]
        }
      },
      {
        "type": "form-select",
        "name": "任务表单",
        "value": "form.form_id",
        "mode": "form",
        "option": {
          "model": "crm.NewFormModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "name"
          ],
          "filters": {
            "status": 1
          }
        },
        "meta": {
          "formLayout": "horizontal",
          "tab": "basic",
          "hiddenCondition": "all",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "form"
            },
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "approval"
            }
          ]
        }
      },
      {
        "type": "form-select",
        "name": "核验规则",
        "value": "form.script_id",
        "mode": "form",
        "option": {
          "model": "crm.NewRuleScriptModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "name"
          ],
          "filters": {
            "status": 1
          }
        },
        "meta": {
          "formLayout": "horizontal",
          "tab": "basic",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "rule"
            }
          ]
        }
      },
      {
        "type": "form-switch",
        "name": "必做任务",
        "value": "form.required",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "tab": "basic",
          "trueValue": true,
          "falseValue": false
        }
      },
      {
        "type": "form-radio",
        "name": "负责方式",
        "value": "form.assignee_mode",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "负责方式不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "basic",
          "clearOnChange": [
            "form.assignee_department_id"
          ]
        }
      },
      {
        "type": "form-select",
        "name": "负责部门",
        "value": "form.assignee_department_id",
        "mode": "form",
        "option": {
          "model": "crm.NewDepartmentModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "name"
          ],
          "filters": {
            "status": 1
          }
        },
        "meta": {
          "formLayout": "horizontal",
          "tab": "basic",
          "hiddenWhen": [
            {
              "path": "form.assignee_mode",
              "operator": "equals",
              "value": "stage"
            }
          ]
        }
      },
      {
        "type": "form-number",
        "name": "办理期限（天）",
        "value": "form.due_days",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "tab": "basic",
          "min": 0,
          "step": 1
        }
      },
      {
        "type": "form-radio",
        "name": "创建方式",
        "value": "form.activation_mode",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "请选择任务创建方式。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "flow"
        }
      },
      {
        "type": "form-select",
        "name": "适用条件",
        "value": "form.condition_script_id",
        "placeholder": "不选则全部创建",
        "mode": "form",
        "option": {
          "model": "crm.NewRuleScriptModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "name"
          ],
          "filters": {
            "status": 1
          }
        },
        "meta": {
          "formLayout": "horizontal",
          "tab": "flow"
        }
      },
      {
        "type": "form-select",
        "name": "驳回后回到",
        "value": "form.reject_target_task_id",
        "placeholder": "不选则保留当前审核",
        "mode": "form",
        "option": {
          "model": "crm.NewTaskModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "name"
          ],
          "filters": {
            "status": 1
          }
        },
        "meta": {
          "formLayout": "horizontal",
          "tab": "flow",
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "approval"
            }
          ]
        }
      },
      {
        "type": "form-select",
        "name": "完成后触发",
        "value": "form.complete_target_task_id",
        "placeholder": "不选则正常推进",
        "mode": "form",
        "option": {
          "model": "crm.NewTaskModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "name"
          ],
          "filters": {
            "status": 1
          }
        },
        "meta": {
          "formLayout": "horizontal",
          "tab": "flow"
        }
      },
      {
        "type": "form-switch",
        "name": "预约会议",
        "value": "form.meeting_enabled",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "tab": "capability",
          "trueValue": true,
          "falseValue": false,
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "form"
            }
          ]
        }
      },
      {
        "type": "form-switch",
        "name": "下次跟进",
        "value": "form.customer_follow_enabled",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "tab": "capability",
          "trueValue": true,
          "falseValue": false,
          "hiddenWhen": [
            {
              "path": "form.task_type",
              "operator": "notEquals",
              "value": "form"
            }
          ]
        }
      },
      {
        "type": "form-switch",
        "name": "负责人参会",
        "value": "form.include_in_meeting",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "tab": "capability",
          "trueValue": true,
          "falseValue": false
        }
      }
    ]
  },
  "data": {
    "form": {
      "_fields": [
        "stage_id",
        "name",
        "task_type",
        "required",
        "assignee_mode",
        "assignee_department_id",
        "form_id",
        "script_id",
        "activation_mode",
        "condition_script_id",
        "reject_target_task_id",
        "complete_target_task_id",
        "meeting_enabled",
        "customer_follow_enabled",
        "include_in_meeting",
        "due_days"
      ],
      "stage_id": "",
      "name": "",
      "task_type": "todo",
      "required": true,
      "assignee_mode": "stage",
      "assignee_department_id": "",
      "form_id": "",
      "script_id": "",
      "activation_mode": "stage",
      "condition_script_id": "",
      "reject_target_task_id": "",
      "complete_target_task_id": "",
      "meeting_enabled": false,
      "customer_follow_enabled": false,
      "include_in_meeting": false,
      "due_days": 0,
      "sort": 100,
      "status": 1
    }
  },
  "state": {
    "currentTab": "basic"
  },
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "crm.setting.CrmHook.BeforeSaveTask"
      }
    }
  }
}
