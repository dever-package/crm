{
  "page": {
    "parent": "crm/task/update",
    "type": 2
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "name": "结果名称",
        "value": "form.name",
        "mode": "form",
        "placeholder": "例如：通过",
        "validate": [
          {
            "type": "required",
            "message": "结果名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "name": "结果值",
        "value": "form.result_value",
        "mode": "form",
        "placeholder": "例如：pass",
        "validate": [
          {
            "type": "required",
            "message": "结果值不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-switch",
        "name": "成功结果",
        "value": "form.is_success",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "trueValue": true,
          "falseValue": false
        }
      },
      {
        "type": "form-switch",
        "name": "需要备注",
        "value": "form.requires_comment",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "trueValue": true,
          "falseValue": false
        }
      }
    ]
  },
  "data": {
    "form": {
      "name": "",
      "result_value": "",
      "is_success": false,
      "requires_comment": false,
      "sort": 100
    }
  },
  "state": {},
  "action": {}
}
