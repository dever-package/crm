{
  "page": {
    "name": "渠道编辑",
    "parent": "crm/customer_channel/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/customer_channel/create",
        "name": "渠道新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/customer_channel/update",
        "name": "渠道编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "value": "form.code",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "渠道标识不能为空。"
          },
          {
            "type": "model",
            "except": "$form.id",
            "message": "渠道标识已存在。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "渠道名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": "",
      "code": "",
      "name": ""
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "crm.setting.CrmHook.BeforeSaveCustomerChannel"
      }
    }
  }
}
