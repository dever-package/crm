{
  "page": {
    "name": "选项集编辑",
    "parent": "crm/option_set/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/option_set/create",
        "name": "选项集新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/option_set/update",
        "name": "选项集编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "选项集名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-array",
        "name": "选项",
        "value": "form.items",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "pageRoute": "/crm/option_set_item/update",
          "addText": "添加选项",
          "drag": "sort"
        }
      }
    ]
  },
  "data": {
    "form": {
      "_fields": [
        "name",
        "items"
      ],
      "service": "crm.setting.CrmHook.BuildOptionSetForm",
      "id": "",
      "name": "",
      "items": [],
      "status": 1,
      "sort": 100
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "crm.setting.CrmHook.BeforeSaveOptionSet"
      }
    }
  }
}
