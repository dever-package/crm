{
  "page": {
    "name": "收集数据编辑",
    "parent": "crm/task_template/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/task_field/create",
        "name": "收集数据新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/task_field/update",
        "name": "收集数据编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-switch",
        "name": "是否必填",
        "value": "form.required",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "trueValue": true,
          "falseValue": false
        }
      },
      {
        "type": "form-cascader",
        "name": "收集数据",
        "value": "form.collect_path",
        "mode": "form",
        "placeholder": "请选择收集数据",
        "validate": [
          {
            "type": "required",
            "message": "收集数据不能为空。"
          }
        ],
        "meta": {
          "api": "/front/route/option",
          "type": "service",
          "use": "crm.setting.OptionService.LoadTaskCollectCascaderOptions",
          "formLayout": "horizontal",
          "controlClassName": "w-[9rem] min-w-[9rem]",
          "requiredLevels": 3,
          "placeholder": [
            "选择模板分类",
            "选择数据模板",
            "选择数据字段"
          ]
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": "",
      "task_template_id": "",
      "collect_path": [],
      "collect_labels": [],
      "service": "crm.setting.CrmHook.BuildTaskFieldForm",
      "data_template_cate_id": "",
      "data_template_id": "",
      "field_source": "",
      "main_field": "",
      "data_field_id": "",
      "name": "",
      "required": true,
      "status": 1,
      "sort": 100
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "type": "service",
        "use": "crm.setting.CrmHook.BeforeSaveTaskField"
      }
    }
  }
}
