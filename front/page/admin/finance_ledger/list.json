{
  "page": {
    "name": "财务流水",
    "icon": "receipt-text",
    "parent": "crm-customer-manage",
    "sort": 5
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header"
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5",
        "children": {
          "toolbar-row": {
            "type": "row",
            "className": "flex-wrap items-center gap-3"
          },
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page"
      }
    ],
    "toolbar-row": [
      {
        "type": "form-input",
        "placeholder": "搜索财务类型、原始值...",
        "value": "search.keyword",
        "mode": "search"
      },
      {
        "type": "form-select",
        "placeholder": "客户产品",
        "value": "search.customer_product_id",
        "mode": "search",
        "option": {
          "model": "crm.NewCustomerProductModel",
          "labelField": "id",
          "order": "id desc",
          "pageSize": 200
        }
      },
      {
        "type": "form-select",
        "placeholder": "流程实例",
        "value": "search.workflow_instance_id",
        "mode": "search",
        "option": {
          "model": "crm.NewWorkflowInstanceModel",
          "labelField": "id",
          "order": "id desc",
          "pageSize": 200
        }
      },
      {
        "type": "form-select",
        "placeholder": "任务",
        "value": "search.task_id",
        "mode": "search",
        "option": {
          "model": "crm.NewTaskModel",
          "labelField": "name",
          "order": "stage_id asc,sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "name"
          ],
          "filters": {
            "status": "1"
          }
        }
      },
      {
        "type": "form-select",
        "placeholder": "操作人",
        "value": "search.staff_id",
        "mode": "search",
        "option": {
          "model": "crm.NewStaffModel",
          "labelField": "name",
          "order": "id asc",
          "pageSize": 200,
          "searchFields": [
            "name",
            "phone"
          ],
          "filters": {
            "status": "1"
          }
        }
      },
      {
        "type": "form-select",
        "placeholder": "部门",
        "value": "search.department_id",
        "mode": "search",
        "option": {
          "model": "crm.NewDepartmentModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "code",
            "name"
          ],
          "filters": {
            "status": "1"
          }
        }
      },
      {
        "type": "form-date",
        "placeholder": "创建时间",
        "value": "search.created_at_start",
        "mode": "search",
        "meta": {
          "searchWidth": "select",
          "range": true,
          "endValue": "search.created_at_end",
          "inputType": "datetime-local"
        }
      },
      {
        "type": "show-button",
        "name": "搜索",
        "meta": {
          "variant": "default",
          "size": "sm",
          "searchSubmit": true
        }
      },
      {
        "type": "show-button",
        "name": "重置",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "to": "/crm/finance_ledger/list"
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "rowKey": "id",
          "columns": [
            {
              "name": "客户",
              "value": "customer.name",
              "type": "show-base"
            },
            {
              "name": "资产",
              "value": "asset.asset_name",
              "type": "show-base"
            },
            {
              "name": "客户产品",
              "value": "customer_product.product.name",
              "type": "show-base"
            },
            {
              "name": "流程",
              "value": "workflow_instance.workflow.name",
              "type": "show-base"
            },
            {
              "name": "财务类型",
              "value": "finance_type_name",
              "type": "show-base"
            },
            {
              "name": "类型编码",
              "value": "finance_type_code",
              "type": "show-base"
            },
            {
              "name": "方向",
              "value": "direction",
              "type": "show-tag"
            },
            {
              "name": "来源",
              "value": "source",
              "type": "show-tag"
            },
            {
              "name": "金额",
              "value": "amount",
              "type": "show-base"
            },
            {
              "name": "任务",
              "value": "task.name",
              "type": "show-base"
            },
            {
              "name": "操作人",
              "value": "staff.name",
              "type": "show-base"
            },
            {
              "name": "创建时间",
              "value": "created_at",
              "type": "show-date"
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ]
  },
  "data": {
    "search": {
      "keyword": "",
      "task_id": "",
      "customer_product_id": "",
      "workflow_instance_id": "",
      "staff_id": "",
      "department_id": "",
      "created_at_start": "",
      "created_at_end": ""
    },
    "table": {
      "pageSize": 20,
      "searchFields": [
        "finance_type_code",
        "finance_type_name",
        "raw_value"
      ],
      "filterFields": [
        "task_id",
        "customer_product_id",
        "workflow_instance_id",
        "staff_id",
        "department_id",
        {
          "field": "created_at",
          "type": "date-range",
          "startKey": "created_at_start",
          "endKey": "created_at_end",
          "valueType": "datetime"
        }
      ]
    }
  },
  "state": {},
  "action": {}
}
