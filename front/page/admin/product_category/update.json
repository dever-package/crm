{
  "page": {
    "name": "产品分类编辑",
    "parent": "crm/product_category/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/product_category/create",
        "name": "产品分类新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/product_category/update",
        "name": "产品分类编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "name": "分类名称",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "产品分类名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-number",
        "name": "排序",
        "value": "form.sort",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "min": 0,
          "step": 10
        }
      },
      {
        "type": "form-switch",
        "name": "启用",
        "value": "form.status",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "trueValue": 1,
          "falseValue": 2
        }
      }
    ]
  },
  "data": {
    "form": {
      "_fields": [
        "name",
        "sort",
        "status"
      ],
      "id": "",
      "name": "",
      "sort": 100,
      "status": 1
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "crm.setting.CrmHook.BeforeSaveProductCategory"
      }
    }
  }
}
