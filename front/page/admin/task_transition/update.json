{
  "page": {
    "name": "任务流转编辑",
    "parent": "crm/task_transition/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/task_transition/create",
        "name": "任务流转新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/task_transition/update",
        "name": "任务流转编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-select",
        "value": "form.flow_template_id",
        "mode": "form",
        "option": "/front/route/option?type=model&use=crm.NewFlowTemplateModel&labelField=name&searchFields=name&pageSize=200&order=sort asc,id asc",
        "validate": [
          {
            "type": "required",
            "message": "流程模板不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-select",
        "value": "form.from_task_template_id",
        "mode": "form",
        "option": "/front/route/option?type=model&use=crm.NewTaskTemplateModel&parentField=flow_template_id&labelField=name&searchFields=task_key,name&pageSize=200&order=sort asc,id asc",
        "validate": [
          {
            "type": "required",
            "message": "来源任务不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "value": "form.match_result",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-select",
        "value": "form.match_script_id",
        "mode": "form",
        "option": "/front/route/option?type=model&use=crm.NewRuleScriptModel&filterField=usage&filterValue=transition&labelField=name&searchFields=name,description&pageSize=200&order=sort asc,id asc",
        "meta": {
          "formLayout": "horizontal",
          "createOption": {
            "name": "新增脚本",
            "pageRoute": "/crm/rule_script/update",
            "size": "xl",
            "bodyClassName": "px-6 py-2",
            "selectCreated": true
          }
        }
      },
      {
        "type": "form-select",
        "value": "form.to_stage_id",
        "mode": "form",
        "option": "/front/route/option?type=model&use=crm.NewFlowStageModel&parentField=flow_template_id&labelField=name&searchFields=stage_key,name&pageSize=200&order=sort asc,id asc",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-select",
        "value": "form.to_task_template_id",
        "mode": "form",
        "option": "/front/route/option?type=model&use=crm.NewTaskTemplateModel&parentField=flow_template_id&labelField=name&searchFields=task_key,name&pageSize=200&order=sort asc,id asc",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-select",
        "value": "form.target_resource_status",
        "mode": "form",
        "option": "option.target_resource_status",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-select",
        "value": "form.target_department_id",
        "mode": "form",
        "option": "/front/route/option?type=model&use=crm.NewDepartmentModel&labelField=name&searchFields=name,code&pageSize=200&order=sort asc,id asc",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-textarea",
        "value": "form.condition_json",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "rows": 3
        }
      },
      {
        "type": "form-radio",
        "value": "form.status",
        "mode": "form",
        "option": "option.status",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-number",
        "value": "form.sort",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": "",
      "flow_template_id": "",
      "from_task_template_id": "",
      "match_result": "",
      "match_script_id": "",
      "to_stage_id": "",
      "to_task_template_id": "",
      "target_resource_status": "",
      "target_department_id": "",
      "target_role_id": "",
      "condition_json": "{}",
      "status": 1,
      "sort": 100
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form"
    }
  }
}
