{
  "page": {
    "name": "人员管理",
    "icon": "users",
    "parent": "crm-org-manage",
    "sort": 1
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5 sm:gap-6",
        "children": {
          "content-shell": {
            "type": "container",
            "className": "front-two-pane-layout",
            "children": {
              "department-column": {
                "type": "container",
                "className": "min-w-0"
              },
              "staff-column": {
                "type": "container",
                "className": "flex min-w-0 flex-col gap-4",
                "children": {
                  "table-row": {
                    "type": "container",
                    "className": "overflow-hidden rounded-md border bg-background"
                  }
                }
              }
            }
          },
          "feedback-shell": {
            "type": "container"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "name": "新增人员",
        "meta": {
          "variant": "default",
          "size": "sm"
        },
        "className": "shrink-0",
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.create",
            "value": true
          }
        }
      }
    ],
    "department-column": [
      {
        "type": "show-category-list",
        "id": "crm-department-list",
        "value": "search.department_id",
        "option": "/front/route/option?type=model&use=crm.NewDepartmentModel&filterField=status&filterValue=1&labelField=name&searchFields=name&order=sort asc,id asc&extraFields=status,sort",
        "meta": {
          "title": "部门管理",
          "description": "左侧选择部门，右侧维护该部门人员。",
          "remote": true,
          "defaultFirst": true,
          "queryKey": "department_id",
          "createButton": {
            "name": "新增部门",
            "icon": "plus",
            "variant": "outline",
            "size": "sm",
            "action": {
              "click": {
                "type": "modal",
                "key": "dialog.createDepartment",
                "value": true
              }
            }
          },
          "buttons": [
            {
              "icon": "square-pen",
              "variant": "ghost",
              "size": "sm",
              "description": "编辑当前部门",
              "action": {
                "click": [
                  {
                    "type": "data",
                    "key": "actionTarget.editDepartmentId",
                    "value": "$row.id"
                  },
                  {
                    "type": "modal",
                    "key": "dialog.editDepartment",
                    "value": true
                  }
                ]
              }
            }
          ]
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "savePath": "crm/staff/update",
          "rowKey": "id",
          "columns": [
            {
              "value": "id",
              "type": "show-base",
              "name": "ID"
            },
            {
              "value": "name",
              "type": "show-base",
              "name": "姓名"
            },
            {
              "value": "phone",
              "type": "show-base",
              "name": "手机号"
            },
            {
              "value": "staff_type_name",
              "type": "show-tag",
              "name": "类型"
            },
            {
              "value": "status",
              "name": "状态",
              "type": "form-switch",
              "meta": {
                "trueValue": 1,
                "falseValue": 2
              }
            },
            {
              "value": "created_at",
              "type": "show-date"
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "编辑人员",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.editStaffId",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.edit",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "feedback-shell": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.edit",
          "pageRoute": "/crm/staff/update",
          "title": "编辑人员",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.editStaffId"
          },
          "bodyClassName": "px-6 py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.create",
          "pageRoute": "/crm/staff/update",
          "title": "新增人员",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "department_id": "data.search.department_id"
          },
          "bodyClassName": "px-6 py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.editDepartment",
          "pageRoute": "/crm/department/update",
          "title": "编辑部门",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.editDepartmentId"
          },
          "bodyClassName": "px-6 py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.createDepartment",
          "pageRoute": "/crm/department/update",
          "title": "新增部门",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "bodyClassName": "px-6 py-2"
        }
      }
    ]
  },
  "data": {
    "search": {
      "department_id": 1
    },
    "table": {
      "page": 1,
      "pageSize": 20,
      "total": 0,
      "service": "crm.setting.CrmHook.BuildStaffRows",
      "searchFields": [
        "name",
        "phone"
      ],
      "filterFields": [
        "department_id"
      ]
    },
    "actionTarget": {
      "editStaffId": "",
      "editDepartmentId": ""
    }
  },
  "state": {
    "dialog": {
      "edit": false,
      "create": false,
      "editDepartment": false,
      "createDepartment": false
    }
  },
  "action": {}
}
