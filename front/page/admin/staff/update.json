{
  "page": {
    "name": "人员编辑",
    "parent": "crm/staff/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/staff/create",
        "name": "人员新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/staff/update",
        "name": "人员编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "姓名不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-select",
        "value": "form.department_id",
        "mode": "form",
        "option": {
          "model": "crm.NewDepartmentModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "code",
            "name"
          ],
          "filters": {
            "status": "1"
          }
        },
        "validate": [
          {
            "type": "required",
            "message": "部门不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-radio",
        "value": "form.staff_type",
        "mode": "form",
        "option": [
          {
            "id": "leader",
            "value": "负责人"
          },
          {
            "id": "employee",
            "value": "员工"
          }
        ],
        "validate": [
          {
            "type": "required",
            "message": "人员类型不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-switch",
        "name": "流程调度",
        "value": "form.can_dispatch",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "trueValue": true,
          "falseValue": false
        }
      },
      {
        "type": "form-input",
        "value": "form.phone",
        "placeholder": "用于手机号登录或首次飞书登录自动匹配",
        "mode": "form",
        "validate": [
          {
            "type": "pattern",
            "pattern": "^1\\d{10}$",
            "message": "手机号格式不正确。"
          },
          {
            "type": "model",
            "except": "$form.id",
            "message": "该手机号已存在，请更换。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "name": "飞书 OpenID",
        "value": "form.feishu_open_id",
        "placeholder": "首次飞书登录后自动绑定",
        "info": "由飞书登录自动获取，仅供查看。",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "disabled": true
        }
      },
      {
        "type": "form-password",
        "placeholder": "手机号密码登录时使用",
        "value": "form.password",
        "mode": "form",
        "validate": [
          {
            "type": "min",
            "min": 6,
            "message": "密码至少 6 位。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": "",
      "name": "",
      "department_id": 1,
      "staff_type": "employee",
      "can_dispatch": false,
      "phone": "",
      "feishu_open_id": "",
      "password": ""
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "crm.setting.CrmHook.BeforeSaveStaff"
      },
      "after": {
        "service": "crm.setting.CrmHook.AfterSaveStaff"
      }
    }
  }
}
