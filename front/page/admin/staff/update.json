{
  "page": {
    "name": "人员编辑",
    "parent": "crm/staff/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/staff/create",
        "name": "人员新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/staff/update",
        "name": "人员编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "姓名不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-select",
        "value": "form.department_id",
        "mode": "form",
        "option": "/front/route/option?type=model&use=crm.NewDepartmentModel&filterField=status&filterValue=1&labelField=name&searchFields=code,name&order=sort asc,id asc&pageSize=200",
        "validate": [
          {
            "type": "required",
            "message": "部门不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-radio",
        "value": "form.staff_type",
        "mode": "form",
        "option": [
          {
            "id": "leader",
            "value": "负责人"
          },
          {
            "id": "employee",
            "value": "员工"
          }
        ],
        "validate": [
          {
            "type": "required",
            "message": "人员类型不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "value": "form.phone",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "手机号不能为空。"
          },
          {
            "type": "pattern",
            "pattern": "^1\\d{10}$",
            "message": "手机号格式不正确。"
          },
          {
            "type": "model",
            "except": "$form.id",
            "message": "该手机号已存在，请更换。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-password",
        "placeholder": "请输入登录密码",
        "value": "form.password",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "密码不能为空。",
            "when": [
              {
                "path": "form.id",
                "operator": "empty"
              }
            ]
          },
          {
            "type": "min",
            "min": 6,
            "message": "密码至少 6 位。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": "",
      "name": "",
      "department_id": 1,
      "staff_type": "employee",
      "phone": "",
      "password": ""
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "type": "service",
        "use": "crm.setting.CrmHook.BeforeSaveStaff"
      },
      "after": {
        "type": "service",
        "use": "crm.setting.CrmHook.AfterSaveStaff"
      }
    }
  }
}
