{
  "page": {
    "name": "沟通群类型编辑",
    "parent": "crm/communication_group_type/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/communication_group_type/create",
        "name": "群类型新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/communication_group_type/update",
        "name": "群类型编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "类型名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "value": "form.code",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "类型编码不能为空。"
          },
          {
            "type": "model",
            "except": "$form.id",
            "message": "类型编码已存在。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-textarea",
        "value": "form.description",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "rows": 3
        }
      }
    ]
  },
  "data": {
    "form": {
      "_fields": [
        "name",
        "code",
        "description"
      ],
      "id": "",
      "name": "",
      "code": "",
      "description": "",
      "sort": 100,
      "status": 1
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "crm.setting.CrmHook.BeforeSaveCommunicationGroupType"
      }
    }
  }
}
