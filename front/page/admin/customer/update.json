{
  "page": {
    "name": "客户编辑",
    "parent": "crm/customer/list",
    "type": 2,
    "sort": 10,
    "auth": [
      {
        "key": "crm/customer/create",
        "name": "客户新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/customer/update",
        "name": "客户编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "姓名不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "value": "form.phone",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "手机号不能为空。"
          },
          {
            "type": "model",
            "except": "$form.id",
            "message": "手机号已存在。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "value": "form.wechat",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "value": "form.id_card",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-radio",
        "value": "form.gender",
        "mode": "form",
        "option": "option.gender",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-select",
        "value": "form.source_id",
        "mode": "form",
        "option": {
          "model": "crm.NewCustomerSourceModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "code",
            "name"
          ]
        },
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-select",
        "value": "form.channel_id",
        "mode": "form",
        "option": {
          "model": "crm.NewCustomerChannelModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "code",
            "name"
          ]
        },
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-crm-customer-tags",
        "name": "标签",
        "value": "form.tag_ids",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "optionsPath": "form.tag_options"
        }
      },
      {
        "type": "form-textarea",
        "value": "form.remark",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "rows": 4
        }
      }
    ]
  },
  "data": {
    "form": {
      "service": "crm.setting.CrmHook.BuildCustomerForm",
      "id": "",
      "name": "",
      "phone": "",
      "wechat": "",
      "id_card": "",
      "gender": "unknown",
      "source_id": 1,
      "channel_id": 1,
      "level_id": 0,
      "tags": "",
      "tag_ids": [],
      "tag_options": [],
      "remark": ""
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "crm.setting.CrmHook.BeforeSaveCustomer"
      },
      "after": {
        "service": "crm.setting.CrmHook.AfterSaveCustomer"
      }
    }
  }
}
