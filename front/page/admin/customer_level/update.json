{
  "page": {
    "name": "等级编辑",
    "parent": "crm/customer_level/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/customer_level/create",
        "name": "等级新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/customer_level/update",
        "name": "等级编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "等级名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-array",
        "name": "等级标签",
        "value": "form.tags",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "pageRoute": "/crm/customer_tag/update",
          "addText": "添加标签",
          "drag": "sort"
        }
      }
    ]
  },
  "data": {
    "form": {
      "_fields": [
        "name",
        "tags"
      ],
      "service": "crm.setting.CrmHook.BuildCustomerLevelForm",
      "id": "",
      "name": "",
      "tags": []
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "crm.setting.CrmHook.BeforeSaveCustomerLevel"
      },
      "after": {
        "service": "crm.setting.CrmHook.AfterSaveCustomerLevel"
      }
    }
  }
}
