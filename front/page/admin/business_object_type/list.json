{
  "page": {
    "name": "业务记录类型",
    "icon": "boxes",
    "parent": "crm-business-config",
    "sort": 9
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "className": "gap-4",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5",
        "children": {
          "toolbar-row": {
            "type": "row",
            "className": "flex-wrap items-center gap-3"
          },
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          },
          "feedback-shell": {
            "type": "container"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page",
        "className": "min-w-0 flex-1"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "name": "新增类型",
        "className": "shrink-0",
        "meta": {
          "variant": "default",
          "size": "sm",
          "icon": "plus"
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.create",
            "value": true
          }
        }
      }
    ],
    "toolbar-row": [
      {
        "type": "form-input",
        "placeholder": "搜索类型名称、编码...",
        "value": "search.keyword",
        "mode": "search"
      },
      {
        "type": "show-button",
        "name": "搜索",
        "meta": {
          "variant": "default",
          "size": "sm",
          "searchSubmit": true
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "savePath": "crm/business_object_type/update",
          "rowKey": "id",
          "columns": [
            {
              "value": "name",
              "name": "类型名称",
              "type": "show-base"
            },
            {
              "value": "code",
              "name": "类型编码",
              "type": "show-base"
            },
            {
              "value": "parent_target",
              "name": "归属对象",
              "type": "show-tag"
            },
            {
              "value": "status",
              "type": "form-switch",
              "meta": {
                "trueValue": 1,
                "falseValue": 2
              }
            },
            {
              "value": "sort",
              "type": "show-base",
              "editor": "form-number",
              "trigger": "doubleClick"
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "编辑",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.businessObjectTypeId",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.edit",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "feedback-shell": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.create",
          "pageRoute": "/crm/business_object_type/update",
          "title": "新增业务记录类型",
          "assistant": false,
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "size": "md",
          "bodyClassName": "px-6 py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.edit",
          "pageRoute": "/crm/business_object_type/update",
          "title": "编辑业务记录类型",
          "assistant": false,
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.businessObjectTypeId"
          },
          "size": "md",
          "bodyClassName": "px-6 py-2"
        }
      }
    ]
  },
  "data": {
    "search": {},
    "table": {
      "pageSize": 20,
      "searchFields": [
        "name",
        "code"
      ]
    },
    "actionTarget": {
      "businessObjectTypeId": ""
    }
  },
  "state": {
    "dialog": {
      "create": false,
      "edit": false
    }
  },
  "action": {}
}
