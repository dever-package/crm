{
  "page": {
    "name": "业务记录类型编辑",
    "parent": "crm/business_object_type/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/business_object_type/create",
        "name": "业务记录类型新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/business_object_type/update",
        "name": "业务记录类型编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "类型名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "value": "form.code",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "类型编码不能为空。"
          },
          {
            "type": "model",
            "except": "$form.id",
            "message": "类型编码已存在。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-radio",
        "value": "form.parent_target",
        "mode": "form",
        "option": "option.parent_target",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-textarea",
        "value": "form.description",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "rows": 3
        }
      },
      {
        "type": "form-number",
        "value": "form.sort",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": "",
      "name": "",
      "code": "",
      "parent_target": "customer_asset",
      "description": "",
      "sort": 100
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "crm.setting.CrmHook.BeforeSaveBusinessObjectType"
      }
    }
  }
}
