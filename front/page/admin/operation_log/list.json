{
  "page": {
    "name": "操作记录",
    "icon": "clipboard-list",
    "parent": "crm-customer-manage",
    "sort": 3
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header"
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5",
        "children": {
          "toolbar-row": {
            "type": "row",
            "className": "flex-wrap items-center gap-3"
          },
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page"
      }
    ],
    "toolbar-row": [
      {
        "type": "form-input",
        "placeholder": "搜索标题、内容、状态、结果...",
        "value": "search.keyword",
        "mode": "search"
      },
      {
        "type": "form-date",
        "placeholder": "操作时间",
        "value": "search.created_at_start",
        "mode": "search",
        "meta": {
          "searchWidth": "select",
          "range": true,
          "endValue": "search.created_at_end",
          "inputType": "datetime-local"
        }
      },
      {
        "type": "show-button",
        "name": "搜索",
        "meta": {
          "variant": "default",
          "size": "sm",
          "searchSubmit": true
        }
      },
      {
        "type": "show-button",
        "name": "重置",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "to": "/crm/operation_log/list"
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "rowKey": "id",
          "columns": [
            {
              "name": "客户",
              "value": "customer.name",
              "type": "show-base"
            },
            {
              "name": "资产",
              "value": "asset.asset_name",
              "type": "show-base"
            },
            {
              "name": "任务",
              "value": "task.name",
              "type": "show-base"
            },
            {
              "name": "任务类型",
              "value": "task_type_name",
              "type": "show-tag"
            },
            {
              "name": "阶段",
              "value": "stage_code",
              "type": "show-base"
            },
            {
              "name": "结果",
              "value": "result_value_name",
              "type": "show-base"
            },
            {
              "name": "标题",
              "value": "title",
              "type": "show-base"
            },
            {
              "name": "操作人",
              "value": "operator_staff.name",
              "type": "show-base"
            },
            {
              "name": "操作时间",
              "value": "created_at",
              "type": "show-date"
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ]
  },
  "data": {
    "search": {
      "keyword": "",
      "created_at_start": "",
      "created_at_end": ""
    },
    "table": {
      "pageSize": 20,
      "service": "crm.setting.CrmHook.BuildOperationLogRows",
      "searchFields": [
        "title",
        "content",
        "stage_code",
        "result_value"
      ],
      "filterFields": [
        {
          "field": "created_at",
          "type": "date-range",
          "startKey": "created_at_start",
          "endKey": "created_at_end",
          "valueType": "datetime"
        }
      ]
    }
  },
  "state": {},
  "action": {}
}
