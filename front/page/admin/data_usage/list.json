{
  "page": {
    "name": "系统用途",
    "parent": "crm/data_template/list",
    "type": 2
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "className": "gap-4",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5",
        "children": {
          "toolbar-row": {
            "type": "row",
            "className": "flex-wrap items-center gap-3"
          },
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          },
          "feedback-shell": {
            "type": "container"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [],
    "header-actions": [
      {
        "type": "show-button",
        "name": "新增用途",
        "className": "shrink-0",
        "meta": {
          "variant": "default",
          "size": "sm",
          "icon": "plus"
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.create",
            "value": true
          }
        }
      }
    ],
    "toolbar-row": [
      {
        "type": "form-input",
        "placeholder": "搜索用途名称...",
        "value": "search.keyword",
        "mode": "search"
      },
      {
        "type": "form-radio",
        "name": "用途类型",
        "value": "search.usage_type",
        "mode": "search",
        "option": "option.usage_type"
      },
      {
        "type": "show-button",
        "name": "搜索",
        "meta": {
          "variant": "default",
          "size": "sm",
          "searchSubmit": true
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "savePath": "crm/data_usage/update",
          "rowKey": "id",
          "columns": [
            {
              "value": "name",
              "type": "show-base"
            },
            {
              "value": "usage_type",
              "type": "show-tag"
            },
            {
              "name": "字段数量",
              "value": "fields",
              "type": "show-base",
              "meta": {
                "format": "count",
                "countUnit": "个字段"
              }
            },
            {
              "value": "description",
              "type": "show-base"
            },
            {
              "value": "status",
              "type": "form-switch",
              "meta": {
                "trueValue": 1,
                "falseValue": 2
              }
            },
            {
              "value": "sort",
              "type": "show-base",
              "editor": "form-number",
              "trigger": "doubleClick"
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "编辑",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.dataUsageId",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.edit",
                          "value": true
                        }
                      ]
                    }
                  },
                  {
                    "icon": "trash-2",
                    "variant": "outline",
                    "size": "sm",
                    "description": "删除",
                    "className": "text-destructive hover:text-destructive",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.deleteDataUsageId",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.delete",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "feedback-shell": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.create",
          "pageRoute": "/crm/data_usage/update",
          "title": "新增系统用途",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "size": "3xl",
          "bodyClassName": "px-6 py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.edit",
          "pageRoute": "/crm/data_usage/update",
          "title": "编辑系统用途",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.dataUsageId"
          },
          "size": "3xl",
          "bodyClassName": "px-6 py-2"
        }
      },
      {
        "type": "feedback-confirm",
        "name": "删除系统用途",
        "info": "确认删除这一条系统用途吗？删除后无法恢复。",
        "meta": {
          "stateKey": "dialog.delete",
          "successMessage": "系统用途已删除"
        },
        "action": {
          "confirm": {
            "type": "delete",
            "params": "data.actionTarget.deleteDataUsageId"
          }
        }
      }
    ]
  },
  "data": {
    "option": {
      "usage_type": [
        {
          "id": "",
          "value": "全部"
        },
        {
          "id": "stat",
          "value": "统计"
        },
        {
          "id": "finance",
          "value": "财务"
        },
        {
          "id": "display",
          "value": "展示"
        },
        {
          "id": "report",
          "value": "报表"
        }
      ]
    },
    "search": {
      "usage_type": ""
    },
    "table": {
      "pageSize": 20,
      "searchFields": [
        "name",
        "description"
      ],
      "filterFields": [
        "usage_type"
      ]
    },
    "actionTarget": {
      "dataUsageId": "",
      "deleteDataUsageId": ""
    }
  },
  "state": {
    "dialog": {
      "create": false,
      "edit": false,
      "delete": false
    }
  },
  "action": {}
}
