{
  "page": {
    "name": "系统用途编辑",
    "parent": "crm/data_usage/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/data_usage/create",
        "name": "系统用途新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/data_usage/update",
        "name": "系统用途编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full",
            "children": {
              "field-page": {
                "type": "container",
                "path": "/crm/data_usage/field_list",
                "className": "mt-5"
              }
            }
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "用途名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-radio",
        "value": "form.usage_type",
        "mode": "form",
        "option": "option.usage_type",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-textarea",
        "value": "form.description",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "rows": 3
        }
      }
    ]
  },
  "data": {
    "option": {
      "usage_type": [
        {
          "id": "stat",
          "value": "统计"
        },
        {
          "id": "finance",
          "value": "财务"
        },
        {
          "id": "display",
          "value": "展示"
        }
      ]
    },
    "form": {
      "_fields": [
        "name",
        "usage_type",
        "description",
        "fields"
      ],
      "service": "crm.setting.CrmHook.BuildDataUsageForm",
      "id": "",
      "name": "",
      "usage_type": "stat",
      "description": "",
      "fields": [],
      "status": 1,
      "sort": 100
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "crm.setting.CrmHook.BeforeSaveDataUsage"
      }
    }
  }
}
