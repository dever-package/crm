{
  "page": {
    "name": "用途字段",
    "parent": "crm/data_usage/list",
    "type": 2,
    "sort": 11
  },
  "layout": {
    "type": "container",
    "className": "rounded-md border bg-background",
    "children": {
      "page-header": {
        "type": "header",
        "className": "gap-4 border-b px-4 py-3",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "table-row": {
        "type": "container",
        "className": "overflow-hidden"
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "name": "用途字段",
        "info": "维护当前用途关联的数据字段。",
        "className": "min-w-0 flex-1"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "name": "添加字段",
        "meta": {
          "variant": "outline",
          "size": "sm"
        },
        "action": {
          "click": [
            {
              "type": "state",
              "key": "fieldIndex",
              "value": -1
            },
            {
              "type": "state",
              "key": "fieldForm",
              "value": {
                "usage_id": 0,
                "field_path": [],
                "data_field": [],
                "finance_type_id": 0,
                "finance_type": "",
                "display_name": "",
                "status": 1,
                "sort": 100
              }
            },
            {
              "type": "modal",
              "key": "dialog.field",
              "value": true
            }
          ]
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "parent.data.form.fields",
        "meta": {
          "rowKey": "id",
          "columns": [
            {
              "name": "数据字段",
              "value": "data_field",
              "type": "show-base",
              "meta": {
                "separator": " / "
              }
            },
            {
              "name": "财务类型",
              "value": "finance_type",
              "type": "show-base",
              "meta": {
                "separator": " / "
              }
            },
            {
              "name": "展示名称",
              "value": "display_name",
              "type": "show-base"
            },
            {
              "name": "排序",
              "value": "sort",
              "type": "show-base",
              "editor": "form-number",
              "trigger": "doubleClick"
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "编辑字段",
                    "action": {
                      "click": [
                        {
                          "type": "state",
                          "key": "fieldIndex",
                          "value": "$rowIndex"
                        },
                        {
                          "type": "state",
                          "key": "fieldForm",
                          "value": "$row"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.field",
                          "value": true
                        }
                      ]
                    }
                  },
                  {
                    "icon": "trash-2",
                    "variant": "outline",
                    "size": "sm",
                    "description": "删除字段",
                    "className": "text-destructive hover:text-destructive",
                    "action": {
                      "click": [
                        {
                          "type": "state",
                          "key": "deleteFieldIndex",
                          "value": "$rowIndex"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.deleteField",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.field",
          "pageRoute": "/crm/data_usage_field/update",
          "title": "用途字段",
          "size": "xl",
          "width": "52rem",
          "footer": {
            "confirm": true,
            "confirmText": "确定"
          },
          "pageDataPatches": {
            "form": "state.fieldForm"
          }
        },
        "action": {
          "submit": {
            "type": "array",
            "key": "parent.data.form.fields",
            "op": "upsert",
            "index": "state.fieldIndex",
            "value": "$modalForm"
          }
        }
      },
      {
        "type": "feedback-confirm",
        "name": "删除字段",
        "info": "确认删除这一条字段吗？删除后当前行内容将被移除。",
        "meta": {
          "stateKey": "dialog.deleteField",
          "successMessage": "字段已删除"
        },
        "action": {
          "confirm": {
            "type": "array",
            "key": "parent.data.form.fields",
            "op": "remove",
            "index": "state.deleteFieldIndex"
          }
        }
      }
    ]
  },
  "data": {},
  "state": {
    "fieldIndex": -1,
    "deleteFieldIndex": -1,
    "fieldForm": {
      "usage_id": 0,
      "field_path": [],
      "data_field": [],
      "finance_type_id": 0,
      "finance_type": "",
      "display_name": "",
      "status": 1,
      "sort": 100
    },
    "dialog": {
      "field": false,
      "deleteField": false
    }
  },
  "action": {}
}
