{
  "page": {
    "name": "模板字段",
    "icon": "list-plus",
    "parent": "crm/form/list",
    "type": 2
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "children": {
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          },
          "feedback-shell": {
            "type": "container"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "name": "返回资料模板",
        "meta": {
          "icon": "arrow-left",
          "variant": "outline",
          "size": "sm",
          "to": "/crm/form/list"
        }
      },
      {
        "type": "show-button",
        "name": "新增字段",
        "meta": {
          "variant": "default",
          "size": "sm",
          "icon": "plus"
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.create",
            "value": true
          }
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "savePath": "crm/form_field/update",
          "rowKey": "id",
          "columns": [
            {
              "name": "资料模板",
              "value": "form.name",
              "type": "show-base"
            },
            {
              "name": "数据分类",
              "value": "collect_labels.0",
              "type": "show-base"
            },
            {
              "name": "数据模板",
              "value": "collect_labels.1",
              "type": "show-base"
            },
            {
              "name": "字段",
              "value": "collect_labels.2",
              "type": "show-base"
            },
            {
              "name": "是否必填",
              "value": "required",
              "type": "form-switch",
              "meta": {
                "trueValue": true,
                "falseValue": false
              }
            },
            {
              "name": "状态",
              "value": "status",
              "type": "form-switch",
              "meta": {
                "trueValue": 1,
                "falseValue": 2
              }
            },
            {
              "name": "排序",
              "value": "sort",
              "type": "show-base",
              "editor": "form-number",
              "trigger": "doubleClick"
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "编辑",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.editFormFieldId",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.edit",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "feedback-shell": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.edit",
          "pageRoute": "/crm/form_field/update",
          "title": "编辑模板字段",
          "size": "xl",
          "width": "64rem",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.editFormFieldId"
          },
          "bodyClassName": "px-6 py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.create",
          "pageRoute": "/crm/form_field/update",
          "title": "新增模板字段",
          "size": "xl",
          "width": "64rem",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "form_id": "data.search.form_id"
          },
          "bodyClassName": "px-6 py-2"
        }
      }
    ]
  },
  "data": {
    "search": {
      "form_id": ""
    },
    "table": {
      "pageSize": 20,
      "service": "crm.setting.CrmHook.BuildFormFieldRows",
      "searchFields": [
        "name",
        "main_field"
      ]
    },
    "actionTarget": {
      "editFormFieldId": ""
    }
  },
  "state": {
    "dialog": {
      "edit": false,
      "create": false
    }
  },
  "action": {}
}
