{
  "page": {
    "name": "表单字段编辑",
    "parent": "crm/form/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/form_field/create",
        "name": "表单字段新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/form_field/update",
        "name": "表单字段编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-switch",
        "name": "是否必填",
        "value": "form.required",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "trueValue": true,
          "falseValue": false,
          "controlClassName": "min-w-[6rem]"
        }
      },
      {
        "type": "form-cascader",
        "name": "字段",
        "value": "form.field_path",
        "mode": "form",
        "placeholder": "请选择字段",
        "validate": [
          {
            "type": "required",
            "message": "字段不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "parentField": "parent_id",
          "rootValue": 0,
          "valueField": "id",
          "labelField": "name",
          "leafField": "leaf",
          "placeholder": [
            "选择字段来源",
            "选择主表或扩展表",
            "选择字段"
          ],
          "searchPlaceholder": [
            "搜索字段来源...",
            "搜索表名...",
            "搜索字段..."
          ],
          "controlClassName": "min-w-[9.5rem]",
          "service": "crm.setting.OptionService.LoadFormFieldCascaderOptions"
        }
      },
      {
        "type": "form-select",
        "name": "显示条件字段",
        "value": "form.visible_when_field_id",
        "placeholder": "不选择则始终显示",
        "mode": "form",
        "option": {
          "model": "crm.NewDataFieldModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 500,
          "searchFields": [
            "name",
            "field_key"
          ],
          "filters": {
            "status": 1
          }
        },
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-select",
        "name": "显示条件",
        "value": "form.visible_when_operator",
        "placeholder": "请选择显示条件",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "hiddenWhen": [
            {
              "path": "form.visible_when_field_id",
              "operator": "empty"
            }
          ]
        }
      },
      {
        "type": "form-input",
        "name": "条件值",
        "value": "form.visible_when_value",
        "placeholder": "多个值可用英文逗号分隔",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "hiddenCondition": "any",
          "hiddenWhen": [
            {
              "path": "form.visible_when_field_id",
              "operator": "empty"
            },
            {
              "path": "form.visible_when_operator",
              "operator": "equals",
              "value": "empty"
            },
            {
              "path": "form.visible_when_operator",
              "operator": "equals",
              "value": "not_empty"
            }
          ]
        }
      }
    ]
  },
  "data": {
    "form": {
      "_fields": [
        "form_id",
        "field_path",
        "required",
        "name",
        "visible_when_field_id",
        "visible_when_operator",
        "visible_when_value",
        "sort"
      ],
      "service": "crm.setting.CrmHook.BuildFormFieldForm",
      "id": "",
      "form_id": "",
      "field_path": [],
      "required": true,
      "name": "",
      "visible_when_field_id": "",
      "visible_when_operator": "equals",
      "visible_when_value": "",
      "sort": 100
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "crm.setting.CrmHook.BeforeSaveFormField"
      }
    }
  }
}
