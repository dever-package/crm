{
  "page": {
    "name": "用途字段编辑",
    "parent": "crm/data_usage/list",
    "type": 2
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "grid grid-cols-1 gap-x-5 md:grid-cols-2"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-cascader",
        "name": "数据字段",
        "value": "form.field_path",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "数据字段不能为空。"
          }
        ],
        "meta": {
          "formLayout": "vertical",
          "parentField": "parent_id",
          "rootValue": 0,
          "valueField": "id",
          "labelField": "name",
          "labelTarget": "form.data_field",
          "leafField": "leaf",
          "placeholder": [
            "选择客户或资产",
            "选择数据模板",
            "选择字段分组",
            "选择字段"
          ],
          "searchPlaceholder": [
            "搜索分类...",
            "搜索模板...",
            "搜索字段分组...",
            "搜索字段..."
          ],
          "controlClassName": "min-w-[12rem]",
          "service": "crm.setting.OptionService.LoadDataUsageFieldOptions"
        }
      },
      {
        "type": "form-cascader",
        "name": "财务类型",
        "value": "form.finance_type_id",
        "mode": "form",
        "meta": {
          "formLayout": "vertical",
          "parentField": "parent_id",
          "rootValue": 0,
          "valueField": "id",
          "labelField": "name",
          "labelTarget": "form.finance_type",
          "leafField": "leaf",
          "valueMode": "leaf",
          "placeholder": "财务用途时必选",
          "searchPlaceholder": "搜索财务类型...",
          "controlClassName": "min-w-[12rem]",
          "service": "crm.setting.OptionService.LoadFinanceTypeCascaderOptions"
        }
      },
      {
        "type": "form-input",
        "name": "展示名称",
        "value": "form.display_name",
        "mode": "form",
        "meta": {
          "formLayout": "vertical"
        }
      }
    ]
  },
  "data": {
    "form": {
      "_fields": [
        "usage_id",
        "field_path",
        "finance_type_id",
        "display_name",
        "sort"
      ],
      "service": "crm.setting.CrmHook.BuildDataUsageFieldForm",
      "id": "",
      "usage_id": 0,
      "field_path": [],
      "data_field": [],
      "finance_type_id": 0,
      "finance_type": "",
      "display_name": "",
      "sort": 100,
      "status": 1
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "crm.setting.CrmHook.BeforeSaveDataUsageField"
      }
    }
  }
}
