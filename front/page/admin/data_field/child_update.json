{
  "page": {
    "name": "分组字段",
    "parent": "crm/data_field/update",
    "type": 2
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "name": "字段名称",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "字段名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "name": "字段编码",
        "value": "form.field_key",
        "mode": "form",
        "placeholder": "留空自动生成，例如 cs.mingcheng",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-radio",
        "name": "字段类型",
        "value": "form.field_type",
        "mode": "form",
        "option": [
          {
            "id": "text",
            "value": "单行文本"
          },
          {
            "id": "textarea",
            "value": "多行文本"
          },
          {
            "id": "number",
            "value": "数字"
          },
          {
            "id": "money",
            "value": "金额"
          },
          {
            "id": "date",
            "value": "日期"
          },
          {
            "id": "datetime",
            "value": "时间"
          },
          {
            "id": "radio",
            "value": "单选"
          },
          {
            "id": "checkbox",
            "value": "多选"
          },
          {
            "id": "select",
            "value": "下拉"
          },
          {
            "id": "multi_select",
            "value": "多选下拉"
          },
          {
            "id": "boolean",
            "value": "开关"
          },
          {
            "id": "attachment",
            "value": "附件"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[420px]"
        }
      },
      {
        "type": "form-input",
        "name": "默认值",
        "value": "form.default_value",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-select",
        "name": "财务类型",
        "value": "form.finance_type_id",
        "mode": "form",
        "placeholder": "不登记财务",
        "option": {
          "model": "crm.NewFinanceTypeModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "name",
            "code"
          ],
          "filters": {
            "status": 1
          }
        },
        "meta": {
          "formLayout": "horizontal",
          "searchable": true,
          "controlClassName": "max-w-[420px]",
          "hiddenWhen": [
            {
              "path": "form.field_type",
              "operator": "equals",
              "value": "attachment"
            }
          ]
        }
      },
      {
        "type": "form-switch",
        "name": "参与统计",
        "value": "form.stat_enabled",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "trueValue": true,
          "falseValue": false,
          "hiddenWhen": [
            {
              "path": "form.field_type",
              "operator": "equals",
              "value": "attachment"
            }
          ]
        }
      },
      {
        "type": "form-radio",
        "name": "选项来源",
        "value": "form.option_source",
        "mode": "form",
        "option": [
          {
            "id": "custom",
            "value": "私有选项"
          },
          {
            "id": "option_set",
            "value": "常用选项集"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[420px]",
          "clearOnChange": [
            "form.option_set_id"
          ],
          "hiddenCondition": "all",
          "hiddenWhen": [
            {
              "path": "form.field_type",
              "operator": "notEquals",
              "value": "radio"
            },
            {
              "path": "form.field_type",
              "operator": "notEquals",
              "value": "checkbox"
            },
            {
              "path": "form.field_type",
              "operator": "notEquals",
              "value": "select"
            },
            {
              "path": "form.field_type",
              "operator": "notEquals",
              "value": "multi_select"
            }
          ]
        }
      },
      {
        "type": "form-select",
        "name": "常用选项集",
        "value": "form.option_set_id",
        "mode": "form",
        "option": {
          "model": "crm.NewOptionSetModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "name"
          ],
          "filters": {
            "status": "1"
          }
        },
        "meta": {
          "formLayout": "horizontal",
          "placeholder": "请选择常用选项集",
          "hiddenCondition": "any",
          "hiddenWhen": [
            {
              "path": "form.field_type",
              "operator": "notEquals",
              "value": "radio"
            },
            {
              "path": "form.option_source",
              "operator": "notEquals",
              "value": "option_set"
            }
          ]
        }
      },
      {
        "type": "form-select",
        "name": "常用选项集",
        "value": "form.option_set_id",
        "mode": "form",
        "option": {
          "model": "crm.NewOptionSetModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "name"
          ],
          "filters": {
            "status": "1"
          }
        },
        "meta": {
          "formLayout": "horizontal",
          "placeholder": "请选择常用选项集",
          "hiddenCondition": "any",
          "hiddenWhen": [
            {
              "path": "form.field_type",
              "operator": "notEquals",
              "value": "checkbox"
            },
            {
              "path": "form.option_source",
              "operator": "notEquals",
              "value": "option_set"
            }
          ]
        }
      },
      {
        "type": "form-select",
        "name": "常用选项集",
        "value": "form.option_set_id",
        "mode": "form",
        "option": {
          "model": "crm.NewOptionSetModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "name"
          ],
          "filters": {
            "status": "1"
          }
        },
        "meta": {
          "formLayout": "horizontal",
          "placeholder": "请选择常用选项集",
          "hiddenCondition": "any",
          "hiddenWhen": [
            {
              "path": "form.field_type",
              "operator": "notEquals",
              "value": "select"
            },
            {
              "path": "form.option_source",
              "operator": "notEquals",
              "value": "option_set"
            }
          ]
        }
      },
      {
        "type": "form-select",
        "name": "常用选项集",
        "value": "form.option_set_id",
        "mode": "form",
        "option": {
          "model": "crm.NewOptionSetModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "name"
          ],
          "filters": {
            "status": "1"
          }
        },
        "meta": {
          "formLayout": "horizontal",
          "placeholder": "请选择常用选项集",
          "hiddenCondition": "any",
          "hiddenWhen": [
            {
              "path": "form.field_type",
              "operator": "notEquals",
              "value": "multi_select"
            },
            {
              "path": "form.option_source",
              "operator": "notEquals",
              "value": "option_set"
            }
          ]
        }
      },
      {
        "type": "form-array",
        "name": "可选项",
        "value": "form.options",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "pageRoute": "/crm/data_field_option/update",
          "addText": "添加选项",
          "drag": "sort",
          "hiddenCondition": "any",
          "hiddenWhen": [
            {
              "path": "form.field_type",
              "operator": "notEquals",
              "value": "radio"
            },
            {
              "path": "form.option_source",
              "operator": "notEquals",
              "value": "custom"
            }
          ]
        }
      },
      {
        "type": "form-array",
        "name": "可选项",
        "value": "form.options",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "pageRoute": "/crm/data_field_option/update",
          "addText": "添加选项",
          "drag": "sort",
          "hiddenCondition": "any",
          "hiddenWhen": [
            {
              "path": "form.field_type",
              "operator": "notEquals",
              "value": "checkbox"
            },
            {
              "path": "form.option_source",
              "operator": "notEquals",
              "value": "custom"
            }
          ]
        }
      },
      {
        "type": "form-array",
        "name": "可选项",
        "value": "form.options",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "pageRoute": "/crm/data_field_option/update",
          "addText": "添加选项",
          "drag": "sort",
          "hiddenCondition": "any",
          "hiddenWhen": [
            {
              "path": "form.field_type",
              "operator": "notEquals",
              "value": "select"
            },
            {
              "path": "form.option_source",
              "operator": "notEquals",
              "value": "custom"
            }
          ]
        }
      },
      {
        "type": "form-array",
        "name": "可选项",
        "value": "form.options",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "pageRoute": "/crm/data_field_option/update",
          "addText": "添加选项",
          "drag": "sort",
          "hiddenCondition": "any",
          "hiddenWhen": [
            {
              "path": "form.field_type",
              "operator": "notEquals",
              "value": "multi_select"
            },
            {
              "path": "form.option_source",
              "operator": "notEquals",
              "value": "custom"
            }
          ]
        }
      }
    ]
  },
  "data": {
    "form": {
      "_fields": [
        "option_set_id",
        "option_source",
        "name",
        "field_key",
        "field_type",
        "default_value",
        "finance_type_id",
        "stat_enabled",
        "options",
        "status",
        "sort"
      ],
      "option_set_id": "",
      "option_source": "custom",
      "name": "",
      "field_key": "",
      "field_type": "text",
      "default_value": "",
      "finance_type_id": "",
      "stat_enabled": false,
      "options": [],
      "status": 1,
      "sort": 100
    }
  },
  "state": {},
  "action": {}
}
