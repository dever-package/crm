{
  "page": {
    "name": "数据字段编辑",
    "parent": "crm/data_field/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/data_field/create",
        "name": "数据字段新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/data_field/update",
        "name": "数据字段编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "字段名称不能为空。"
          },
          {
            "type": "model",
            "except": "$form.id",
            "message": "该字段名称在当前模板下已存在。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-radio",
        "value": "form.field_type",
        "mode": "form",
        "option": "option.field_type",
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[360px]"
        }
      },
      {
        "type": "form-input",
        "value": "form.default_value",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-array",
        "value": "form.options",
        "mode": "form",
        "info": "维护单选、多选、下拉、多选下拉字段的可选项。",
        "meta": {
          "formLayout": "horizontal",
          "pageRoute": "/crm/data_field_option/update",
          "addText": "添加选项",
          "drag": "sort",
          "hiddenWhen": [
            {
              "path": "form.field_type",
              "operator": "notEquals",
              "value": "radio"
            },
            {
              "path": "form.field_type",
              "operator": "notEquals",
              "value": "checkbox"
            },
            {
              "path": "form.field_type",
              "operator": "notEquals",
              "value": "select"
            },
            {
              "path": "form.field_type",
              "operator": "notEquals",
              "value": "multi_select"
            }
          ]
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": "",
      "name": "",
      "field_type": "text",
      "default_value": "",
      "options": [],
      "status": 1,
      "sort": 100
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "type": "service",
        "use": "crm.setting.CrmHook.BeforeSaveDataField"
      }
    }
  }
}
