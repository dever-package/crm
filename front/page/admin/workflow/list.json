{
  "page": {
    "name": "流程配置",
    "icon": "route",
    "parent": "crm-business-config",
    "sort": 3
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "className": "gap-4",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto flex shrink-0 flex-wrap items-center justify-end gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5 sm:gap-6",
        "children": {
          "workflow-tabs-row": {
            "type": "container",
            "className": "flex min-w-0 items-center overflow-x-auto pb-1"
          },
          "content-shell": {
            "type": "container",
            "className": "front-two-pane-layout",
            "children": {
              "stage-column": {
                "type": "container",
                "className": "min-w-0"
              },
              "task-column": {
                "type": "container",
                "className": "flex min-w-0 flex-col gap-4",
                "children": {
                  "task-toolbar": {
                    "type": "row",
                    "className": "flex-wrap items-center gap-2.5"
                  },
                  "task-table": {
                    "type": "container",
                    "className": "overflow-x-auto rounded-md border bg-background"
                  }
                }
              }
            }
          },
          "feedback-shell": {
            "type": "container"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page",
        "className": "min-w-0 flex-1"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "name": "新增流程",
        "className": "shrink-0",
        "meta": {
          "variant": "default",
          "size": "sm",
          "icon": "plus"
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.createWorkflow",
            "value": true
          }
        }
      },
      {
        "type": "show-button",
        "name": "编辑流程",
        "className": "shrink-0",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "icon": "square-pen",
          "hiddenWhen": [
            {
              "path": "search.workflow_id",
              "operator": "empty"
            }
          ]
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.editWorkflow",
            "value": true
          }
        }
      },
      {
        "type": "show-button",
        "name": "删除流程",
        "className": "shrink-0 text-destructive hover:text-destructive",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "icon": "trash-2",
          "hiddenWhen": [
            {
              "path": "search.workflow_id",
              "operator": "empty"
            }
          ]
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.deleteWorkflow",
            "value": true
          }
        }
      }
    ],
    "workflow-tabs-row": [
      {
        "type": "nav-tab",
        "value": "search.workflow_id",
        "option": {
          "service": "crm.setting.OptionService.LoadWorkflowOptions",
          "valueField": "id",
          "labelField": "name",
          "pageSize": 200
        },
        "meta": {
          "target": "data.search.workflow_id",
          "variant": "pill",
          "remoteSearch": true,
          "queryKey": "workflow_id",
          "searchLayoutId": "task-toolbar"
        }
      }
    ],
    "stage-column": [
      {
        "type": "show-category-list",
        "id": "crm-workflow-stage-list",
        "value": "search.stage_id",
        "option": {
          "service": "crm.setting.OptionService.LoadStageOptions",
          "valueField": "id",
          "labelField": "name",
          "pageSize": 200
        },
        "meta": {
          "title": "阶段",
          "hiddenWhen": [
            {
              "path": "search.workflow_id",
              "operator": "empty"
            }
          ],
          "remote": true,
          "defaultFirst": true,
          "queryKey": "stage_id",
          "optionParams": {
            "parentId": "data.search.workflow_id"
          },
          "optionReloadPaths": [
            "data.search.workflow_id"
          ],
          "sortable": true,
          "sortField": "sort",
          "sortChangeAction": {
            "type": "save",
            "path": "crm/stage/update",
            "params": {
              "_partial": true,
              "id": "$row.id",
              "sort": "$value"
            },
            "before": {
              "service": "crm.setting.CrmHook.BeforeSaveStage"
            }
          },
          "statusField": "status",
          "statusDisplay": "select",
          "statusChangeAction": {
            "type": "save",
            "path": "crm/stage/update",
            "params": {
              "_partial": true,
              "id": "$row.id",
              "status": "$value"
            },
            "before": {
              "service": "crm.setting.CrmHook.BeforeSaveStage"
            }
          },
          "statusCases": [
            {
              "value": 1,
              "text": "启用",
              "tone": "success"
            },
            {
              "value": 2,
              "text": "停用",
              "tone": "muted"
            }
          ],
          "createButton": {
            "name": "新增阶段",
            "icon": "plus",
            "variant": "outline",
            "size": "sm",
            "action": {
              "click": {
                "type": "modal",
                "key": "dialog.createStage",
                "value": true
              }
            }
          },
          "buttons": [
            {
              "icon": "square-pen",
              "variant": "ghost",
              "size": "sm",
              "description": "编辑阶段",
              "action": {
                "click": [
                  {
                    "type": "data",
                    "key": "actionTarget.stageId",
                    "value": "$row.id"
                  },
                  {
                    "type": "modal",
                    "key": "dialog.editStage",
                    "value": true
                  }
                ]
              }
            },
            {
              "icon": "trash-2",
              "variant": "ghost",
              "size": "sm",
              "description": "删除阶段",
              "className": "text-destructive hover:text-destructive",
              "action": {
                "click": [
                  {
                    "type": "data",
                    "key": "actionTarget.deleteStageId",
                    "value": "$row.id"
                  },
                  {
                    "type": "modal",
                    "key": "dialog.deleteStage",
                    "value": true
                  }
                ]
              }
            }
          ]
        }
      }
    ],
    "task-toolbar": [
      {
        "type": "form-input",
        "placeholder": "搜索任务名称...",
        "value": "search.keyword",
        "mode": "search",
        "meta": {
          "hiddenWhen": [
            {
              "path": "search.workflow_id",
              "operator": "empty"
            }
          ]
        }
      },
      {
        "type": "show-button",
        "name": "搜索",
        "meta": {
          "variant": "default",
          "size": "sm",
          "searchSubmit": true,
          "hiddenWhen": [
            {
              "path": "search.workflow_id",
              "operator": "empty"
            }
          ]
        }
      },
      {
        "type": "show-button",
        "name": "新增任务",
        "className": "ms-auto shrink-0",
        "meta": {
          "variant": "default",
          "size": "sm",
          "icon": "plus",
          "hiddenWhen": [
            {
              "path": "search.workflow_id",
              "operator": "empty"
            }
          ]
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.createTask",
            "value": true
          }
        }
      }
    ],
    "task-table": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "savePath": "crm/task/update",
          "rowKey": "id",
          "hiddenWhen": [
            {
              "path": "search.workflow_id",
              "operator": "empty"
            }
          ],
          "columns": [
            {
              "name": "任务",
              "value": "name",
              "type": "show-base"
            },
            {
              "name": "类型",
              "value": "task_type",
              "type": "show-tag"
            },
            {
              "name": "必做",
              "value": "required",
              "type": "form-switch",
              "meta": {
                "trueValue": true,
                "falseValue": false
              }
            },
            {
              "name": "负责方式",
              "value": "assignee_mode",
              "type": "show-tag"
            },
            {
              "name": "负责部门",
              "value": "assignee_department.name",
              "type": "show-base"
            },
            {
              "name": "期限（天）",
              "value": "due_days",
              "type": "show-base"
            },
            {
              "name": "状态",
              "value": "status",
              "type": "form-switch",
              "meta": {
                "trueValue": 1,
                "falseValue": 2
              }
            },
            {
              "name": "排序",
              "value": "sort",
              "type": "show-base",
              "editor": "form-number",
              "trigger": "doubleClick"
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "编辑任务",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.taskId",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.editTask",
                          "value": true
                        }
                      ]
                    }
                  },
                  {
                    "icon": "trash-2",
                    "variant": "outline",
                    "size": "sm",
                    "description": "删除任务",
                    "className": "text-destructive hover:text-destructive",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.deleteTaskId",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.deleteTask",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page",
        "meta": {
          "hiddenWhen": [
            {
              "path": "search.workflow_id",
              "operator": "empty"
            }
          ]
        }
      }
    ],
    "feedback-shell": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.createWorkflow",
          "pageRoute": "/crm/workflow/update",
          "title": "新增流程",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "size": "sm",
          "bodyClassName": "py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.editWorkflow",
          "pageRoute": "/crm/workflow/update",
          "title": "编辑流程",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.search.workflow_id"
          },
          "size": "sm",
          "bodyClassName": "py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.createStage",
          "pageRoute": "/crm/stage/update",
          "title": "新增阶段",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "workflow_id": "data.search.workflow_id"
          },
          "size": "sm",
          "bodyClassName": "py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.editStage",
          "pageRoute": "/crm/stage/update",
          "title": "编辑阶段",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.stageId"
          },
          "size": "sm",
          "bodyClassName": "py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.createTask",
          "pageRoute": "/crm/task/update",
          "title": "新增任务",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "stage_id": "data.search.stage_id"
          },
          "size": "lg",
          "bodyClassName": "px-6 py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.editTask",
          "pageRoute": "/crm/task/update",
          "title": "编辑任务",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.taskId"
          },
          "size": "lg",
          "bodyClassName": "px-6 py-2"
        }
      },
      {
        "type": "feedback-confirm",
        "name": "删除流程",
        "info": "确认删除这个流程吗？",
        "meta": {
          "stateKey": "dialog.deleteWorkflow",
          "successMessage": "流程已删除"
        },
        "action": {
          "confirm": {
            "type": "delete",
            "params": "data.search.workflow_id",
            "before": {
              "service": "crm.setting.CrmHook.BeforeDeleteWorkflow"
            }
          }
        }
      },
      {
        "type": "feedback-confirm",
        "name": "删除阶段",
        "info": "确认删除这个阶段吗？",
        "meta": {
          "stateKey": "dialog.deleteStage",
          "successMessage": "阶段已删除"
        },
        "action": {
          "confirm": {
            "type": "delete",
            "model": "crm.NewStageModel",
            "params": "data.actionTarget.deleteStageId",
            "before": {
              "service": "crm.setting.CrmHook.BeforeDeleteStage"
            }
          }
        }
      },
      {
        "type": "feedback-confirm",
        "name": "删除任务",
        "info": "确认删除这个任务吗？",
        "meta": {
          "stateKey": "dialog.deleteTask",
          "successMessage": "任务已删除"
        },
        "action": {
          "confirm": {
            "type": "delete",
            "model": "crm.NewTaskModel",
            "params": "data.actionTarget.deleteTaskId",
            "before": {
              "service": "crm.setting.CrmHook.BeforeDeleteTask"
            }
          }
        }
      }
    ]
  },
  "data": {
    "search": {
      "service": "crm.setting.OptionService.LoadWorkflowPageState"
    },
    "table": {
      "model": "crm.NewTaskModel",
      "pageSize": 20,
      "defaultFilters": {
        "stage_id": 0
      },
      "searchFields": [
        "name"
      ],
      "filterFields": [
        "stage_id"
      ]
    },
    "actionTarget": {
      "stageId": "",
      "taskId": "",
      "deleteStageId": "",
      "deleteTaskId": ""
    }
  },
  "state": {
    "dialog": {
      "createWorkflow": false,
      "editWorkflow": false,
      "createStage": false,
      "editStage": false,
      "createTask": false,
      "editTask": false,
      "deleteWorkflow": false,
      "deleteStage": false,
      "deleteTask": false
    }
  },
  "action": {}
}
