{
  "page": {
    "name": "流程编辑",
    "parent": "crm/workflow/list",
    "auth": [
      {
        "key": "crm/workflow/create",
        "name": "流程新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/workflow/update",
        "name": "流程编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "name": "流程名称",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "流程名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-radio",
        "name": "流程对象",
        "value": "form.subject_type",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "请选择流程对象。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-switch",
        "name": "默认入口",
        "value": "form.default_entry",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "trueValue": true,
          "falseValue": false
        }
      },
      {
        "type": "form-number",
        "name": "排序",
        "value": "form.sort",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "min": 0,
          "step": 10
        }
      },
      {
        "type": "form-switch",
        "name": "启用",
        "value": "form.status",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "trueValue": 1,
          "falseValue": 2
        }
      }
    ]
  },
  "data": {
    "form": {
      "_fields": ["name", "subject_type", "default_entry", "sort", "status"],
      "name": "",
      "subject_type": "customer_asset",
      "default_entry": false,
      "sort": 100,
      "status": 2
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "crm.setting.CrmHook.BeforeSaveWorkflow"
      }
    }
  }
}
