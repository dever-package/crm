{
  "page": {
    "name": "脚本规则编辑",
    "parent": "crm/rule_script/list",
    "type": 2,
    "auth": [
      {
        "key": "crm/rule_script/create",
        "name": "脚本规则新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/rule_script/update",
        "name": "脚本规则编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-select",
        "value": "form.cate_id",
        "mode": "form",
        "option": "/front/route/option?type=model&use=crm.NewRuleScriptCateModel&filterField=status&filterValue=1&order=sort asc,id asc",
        "validate": [
          {
            "type": "required",
            "message": "脚本分类不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[260px]",
          "createOption": {
            "name": "新增分类",
            "pageRoute": "/crm/rule_script_cate/update",
            "size": "sm",
            "bodyClassName": "py-2",
            "selectCreated": true
          }
        }
      },
      {
        "type": "form-input",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "脚本名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-textarea",
        "value": "form.description",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "rows": 4
        }
      },
      {
        "type": "form-radio",
        "value": "form.usage",
        "mode": "form",
        "option": "option.usage",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "value": "form.language",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "value": "form.entry",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-number",
        "value": "form.timeout_ms",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-textarea",
        "value": "form.script",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "rows": 4
        }
      },
      {
        "type": "form-textarea",
        "value": "form.sample_input",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "rows": 4
        }
      },
      {
        "type": "form-textarea",
        "value": "form.expected_output",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "rows": 4
        }
      },
      {
        "type": "form-radio",
        "value": "form.status",
        "mode": "form",
        "option": "option.status",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-number",
        "value": "form.sort",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": "",
      "cate_id": "",
      "name": "",
      "description": "",
      "usage": "task_rule",
      "language": "javascript",
      "entry": "evaluate",
      "timeout_ms": 100,
      "script": "",
      "sample_input": "{}",
      "expected_output": "{}",
      "status": 1,
      "sort": 100
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form"
    }
  }
}
