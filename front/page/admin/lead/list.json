{
  "page": {
    "name": "线索信息",
    "icon": "users-round",
    "parent": "crm-customer-manage",
    "sort": 0
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5",
        "children": {
          "toolbar-row": {
            "type": "row",
            "className": "flex-wrap items-center gap-2.5"
          },
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "name": "抖音同步",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "icon": "refresh-cw"
        },
        "className": "shrink-0",
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.douyinSync",
            "value": true
          }
        }
      }
    ],
    "toolbar-row": [
      {
        "type": "form-input",
        "placeholder": "搜索编号、姓名、手机、微信或诉求...",
        "value": "search.keyword",
        "mode": "search"
      },
      {
        "type": "form-select",
        "placeholder": "状态",
        "value": "search.status",
        "mode": "search"
      },
      {
        "type": "form-select",
        "placeholder": "来源",
        "value": "search.source_id",
        "mode": "search",
        "option": {
          "model": "crm.NewCustomerSourceModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "filters": {
            "status": 1
          }
        }
      },
      {
        "type": "form-select",
        "placeholder": "渠道",
        "value": "search.channel_id",
        "mode": "search",
        "option": {
          "model": "crm.NewCustomerChannelModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "filters": {
            "status": 1
          }
        }
      },
      {
        "type": "show-button",
        "name": "搜索",
        "meta": {
          "variant": "default",
          "size": "sm",
          "searchSubmit": true
        }
      },
      {
        "type": "show-button",
        "name": "重置",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "to": "/crm/lead/list"
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "rowKey": "id",
          "columns": [
            {
              "value": "code",
              "type": "show-base"
            },
            {
              "value": "name",
              "type": "show-base"
            },
            {
              "value": "phone",
              "type": "show-base"
            },
            {
              "value": "wechat",
              "type": "show-base"
            },
            {
              "name": "来源",
              "value": "source_name",
              "type": "show-base"
            },
            {
              "name": "渠道",
              "value": "channel_name",
              "type": "show-base"
            },
            {
              "value": "city",
              "type": "show-base"
            },
            {
              "value": "initial_need",
              "type": "show-base",
              "className": "max-w-[280px]"
            },
            {
              "value": "status",
              "type": "show-tag"
            },
            {
              "name": "负责人",
              "value": "owner_staff_name",
              "type": "show-base"
            },
            {
              "name": "转化客户",
              "value": "customer_name",
              "type": "show-base"
            },
            {
              "value": "created_at",
              "type": "show-date"
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "page-main": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.douyinSync",
          "pageRoute": "/crm/douyin_sync/set",
          "title": "抖音线索同步",
          "description": "配置抖音来客增量同步；渠道扩展字段保存在“线索信息 / 抖音来客信息”数据模板中。",
          "assistant": false,
          "size": "sm",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "bodyClassName": "px-6 py-2"
        }
      }
    ]
  },
  "data": {
    "search": {
      "keyword": "",
      "status": "",
      "source_id": "",
      "channel_id": ""
    },
    "table": {
      "pageSize": 20,
      "service": "crm.setting.CrmHook.BuildLeadRows",
      "searchFields": [
        "code",
        "name",
        "phone",
        "wechat",
        "external_id",
        "city",
        "initial_need"
      ],
      "filterFields": [
        "status",
        "source_id",
        "channel_id"
      ]
    }
  },
  "state": {
    "dialog": {
      "douyinSync": false
    }
  },
  "action": {}
}
