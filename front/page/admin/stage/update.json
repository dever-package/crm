{
  "page": {
    "name": "阶段编辑",
    "parent": "crm/workflow/list",
    "auth": [
      {
        "key": "crm/stage/create",
        "name": "阶段新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "crm/stage/update",
        "name": "阶段编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "name": "阶段名称",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "阶段名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-select",
        "name": "默认负责部门",
        "value": "form.owner_department_id",
        "mode": "form",
        "option": {
          "model": "crm.NewDepartmentModel",
          "labelField": "name",
          "order": "sort asc,id asc",
          "pageSize": 200,
          "searchFields": [
            "name"
          ],
          "filters": {
            "status": 1
          }
        },
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-number",
        "name": "排序",
        "value": "form.sort",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "min": 0,
          "step": 10
        }
      },
      {
        "type": "form-switch",
        "name": "启用",
        "value": "form.status",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "trueValue": 1,
          "falseValue": 2
        }
      }
    ]
  },
  "data": {
    "form": {
      "_fields": [
        "workflow_id",
        "name",
        "owner_department_id",
        "sort",
        "status"
      ],
      "workflow_id": "",
      "name": "",
      "owner_department_id": "",
      "sort": 100,
      "status": 2
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "crm.setting.CrmHook.BeforeSaveStage"
      }
    }
  }
}
