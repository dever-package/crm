{
  "page": {
    "name": "客户标签编辑",
    "parent": "crm/customer_level/list",
    "type": 2
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "name": "标签名称",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "标签名称不能为空。"
          }
        ]
      },
      {
        "type": "form-switch",
        "name": "启用",
        "value": "form.status",
        "mode": "form",
        "meta": {
          "trueValue": 1,
          "falseValue": 2
        }
      }
    ]
  },
  "data": {
    "form": {
      "name": "",
      "sort": 100,
      "status": 1
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "crm.setting.CrmHook.BeforeSaveCustomerTag"
      }
    }
  }
}
