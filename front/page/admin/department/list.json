{
  "page": {
    "name": "部门管理",
    "icon": "building-2",
    "parent": "crm-org-manage",
    "type": 2,
    "sort": 2
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "children": {
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "name": "新增部门",
        "meta": {
          "variant": "default",
          "size": "sm"
        },
        "className": "shrink-0",
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.create",
            "value": true
          }
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "savePath": "crm/department/update",
          "rowKey": "id",
          "columns": [
            {
              "value": "id",
              "type": "show-base",
              "name": "ID"
            },
            {
              "value": "name",
              "type": "show-base",
              "name": "部门名称"
            },
            {
              "value": "status",
              "type": "form-switch",
              "meta": {
                "trueValue": 1,
                "falseValue": 2
              }
            },
            {
              "value": "sort",
              "type": "show-base",
              "editor": "form-number",
              "trigger": "doubleClick"
            },
            {
              "value": "created_at",
              "type": "show-date"
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "编辑部门",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.editDepartmentId",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.edit",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "page-main": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.edit",
          "pageRoute": "/crm/department/update",
          "title": "编辑部门",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.editDepartmentId"
          },
          "bodyClassName": "px-6 py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.create",
          "pageRoute": "/crm/department/update",
          "title": "新增部门",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "bodyClassName": "px-6 py-2"
        }
      }
    ]
  },
  "data": {
    "table": {
      "page": 1,
      "pageSize": 20,
      "total": 0,
      "searchFields": [
        "name"
      ]
    },
    "actionTarget": {
      "editDepartmentId": ""
    }
  },
  "state": {
    "dialog": {
      "edit": false,
      "create": false
    }
  },
  "action": {}
}
